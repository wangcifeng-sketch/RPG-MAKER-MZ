/*:
 * @target MZ
 * @plugindesc [核心] 地图敌人系统（属性 / AI攻击 / 血条 / 飘字 / 技能驱动）
 * @author CFpanda
 *
 * @command EnemyRespawn
 * @text 敌人重生
 * @desc 当前事件敌人重生
 *
 * @command EnemyAttackPlayer
 * @text 敌人攻击玩家
 * @desc 当前事件攻击玩家
 *
 * @help
 * ============================================================================
 * ■ 插件定位
 * ============================================================================
 * 本插件是【地图即时战斗系统】的敌人核心模块。
 *
 * 作用：
 * ✔ 将事件转为“敌人单位”
 * ✔ 绑定数据库敌人属性
 * ✔ 控制敌人攻击与技能选择
 * ✔ 提供血条、飘字、技能名显示
 * ✔ 驱动敌人AI攻击流程
 *
 * ============================================================================
 * ■ 功能概要
 * ============================================================================
 * 1. 事件敌人化（<enemy:id>）
 * 2. 敌人属性同步数据库
 * 3. 自动选择技能（rating机制）
 * 4. 攻击冷却系统
 * 5. 技能/普通攻击对玩家造成伤害
 * 6. 支持攻击体（AttackObject）联动
 * 7. 敌人血条显示
 * 8. 伤害飘字（MISS / 数字 / 暴击）
 * 9. 技能名提示
 * 10. 敌人HP/MP自动回复
 *
 * ============================================================================
 * ■ 敌人设置（核心）
 * ============================================================================
 * 在事件备注中写：
 *
 * <enemy:1>
 *
 * → 该事件将绑定数据库中的敌人ID 1
 *
 * ============================================================================
 * ■ 战斗机制
 * ============================================================================
 * 敌人攻击流程：
 *
 * 敌人
 *   ↓
 * 选择数据库行动（rating）
 *   ↓
 * 判断距离（range）
 *   ↓
 * 执行技能
 *
 * 分两种：
 *
 * 【有攻击体】
 * → 生成攻击体（延迟发射）
 *
 * 【无攻击体】
 * → 直接结算伤害
 *
 * ============================================================================
 * ■ 技能机制
 * ============================================================================
 * 敌人技能来自：
 * 数据库 → 敌人 → Actions
 *
 * 自动支持：
 * ✔ 命中率（successRate）
 * ✔ 闪避（eva）
 * ✔ 暴击（cri）
 * ✔ 伤害公式（damage formula）
 * ✔ 波动（variance）
 *
 * ============================================================================
 * ■ 距离判定
 * ============================================================================
 * 支持技能备注：
 * <range:3>
 *
 * → 敌人只会在直线范围内释放技能
 *
 * ============================================================================
 * ■ 攻击体联动
 * ============================================================================
 * 如果技能包含：
 *
 * <attackObject:xxx>
 *
 * → 不直接造成伤害
 * → 改为生成攻击体（由 AttackObject 插件处理）
 *
 * ============================================================================
 * ■ UI显示
 * ============================================================================
 * 自动提供：
 *
 * ✔ 敌人血条
 * ✔ 伤害飘字
 * ✔ MISS提示
 * ✔ 技能名称显示
 *
 * ============================================================================
 * ■ 攻击动作（立绘切换）
 * ============================================================================
 * 行走图规则：
 * 正常图：Enemy1
 * 攻击图：Enemy1_attack
 *
 * → 攻击时自动切换动画帧
 *
 * ============================================================================
 * ■ 插件指令
 * ============================================================================
 * ◆ EnemyAttackPlayer
 * 当前事件攻击玩家
 *
 * ◆ EnemyRespawn
 * 当前事件重生敌人
 *
 * ============================================================================
 * ■ 脚本调用
 * ============================================================================
 * ◆ 在移动路线中：
 *
 * this.enemyAttackPlayer();
 * 或：
 * EnemyAttackPlayer(eventId);
 *
 * ============================================================================
 * ■ 注意事项
 * ============================================================================
 * - 敌人必须绑定 <enemy:id>
 * - 玩家默认使用“队长”作为战斗对象
 * - 无攻击体技能会立即结算伤害
 *
 * ============================================================================
 * ■ 依赖关系
 * ============================================================================
 * 推荐搭配：
 * ✔ CF_Attack（玩家输入）
 * ✔ CF_AttackObject（攻击体系统）
 *
 * 插件顺序：
 * 1. CF_Attack
 * 2. CF_AttackObject
 * 3. 本插件（Enemy）
 *
 * ============================================================================
 * ■ 扩展建议
 * ============================================================================
 * 可扩展：
 *
 * ✔ 敌人AI（巡逻 / 追击）
 * ✔ 仇恨系统
 * ✔ 技能释放前摇 / 后摇
 * ✔ 多段技能
 *
 * ============================================================================
 * ■ 作者说明
 * ============================================================================
 * 本插件为 CFpanda 地图ARPG系统核心模块
 *
 * ============================================================================
 */

(function() {

    //==================================================
    // 1. 事件敌人属性初始化
    //==================================================
    var _Game_Event_setupPage = Game_Event.prototype.setupPage;
    Game_Event.prototype.setupPage = function() {
        _Game_Event_setupPage.call(this);
        this.initEnemyEntity();
    };

Game_Event.prototype.initEnemyEntity = function() {
    if (!this.event()) return;

    var note = this.event().note || "";
    var enemyMatch = note.match(/<enemy:(\d+)>/i);

    if (enemyMatch) {
        var enemyId = Number(enemyMatch[1]);

        // 只有第一次，或者 enemyId 变化时，才重新创建敌人实体
        if (!this._enemyEntity || this._enemyId !== enemyId) {
            this._enemyId = enemyId;
            this._enemyEntity = new Game_Enemy(enemyId, 0, 0);

            // 只在第一次创建时初始化 HP
            if (this._hp == null) {
                this._hp = this._enemyEntity.mhp;
            }
        } else {
            // 如果敌人实体已经存在，就不要重置 HP / MP
            // 只保证 _hp 至少有值
            if (this._hp == null) {
                this._hp = this._enemyEntity.hp;
            }
        }
    } else {
        this._enemyId = 0;
        this._enemyEntity = null;
        this._hp = 0;
    }

    if (this._attackCooldown == null) this._attackCooldown = 0;
};
    //==================================================
    // 2. 敌人属性映射
    //==================================================
