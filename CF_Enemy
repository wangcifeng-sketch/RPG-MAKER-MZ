        get: function() { return this._enemyEntity ? this._enemyEntity.cri : 0; },
        configurable: true
    });

    //==================================================
    // 3. 飘字系统（MISS / 数字）
    //==================================================
Game_Character.prototype.showDamageText = function(text, color) {
    if (!this._damageTexts) this._damageTexts = [];

    this._damageTexts.push({
        text: String(text || ""),
        color: color || "#ffffff",
        duration: 60,
        vy: -1.2,
        offsetY: this._damageTexts.length * 16   // 后来的字稍微错开
    });
};

    Game_Character.prototype.showSkillNameText = function(text, color) {
        this._skillNameText = {
            text: String(text || ""),
            color: color || "#66ccff",
            duration: 45,
            vy: -0.8
        };
    };

    //==================================================
    // 4. Sprite_Character：血条 + 飘字
    //==================================================
    var _Sprite_Character_update = Sprite_Character.prototype.update;
    Sprite_Character.prototype.update = function() {
        _Sprite_Character_update.call(this);
        this.updateEnemyUI();
        this.updateDamageText();
        this.updateSkillNameText();
    };

Sprite_Character.prototype.updateSkillNameText = function() {
    var char = this._character;
    if (!char || !char._skillNameText) return;

    if (!this._skillNameSprite) {
        this.createSkillNameSprite();
    }

    var data = char._skillNameText;
    var sprite = this._skillNameSprite;

    if (!sprite._initialized) {
        this.refreshSkillNameText(data.text, data.color);
        sprite.visible = true;
        sprite.opacity = 255;
        sprite.y = -52;   // 比血条更高一点
        sprite._initialized = true;
    }

    sprite.y += data.vy;
    sprite.opacity -= 5;
    data.duration--;

    if (data.duration <= 0) {
        sprite.visible = false;
        sprite.opacity = 255;
        sprite.y = -52;
        sprite._initialized = false;
        char._skillNameText = null;
    }
};

Sprite_Character.prototype.createSkillNameSprite = function() {
    this._skillNameSprite = new Sprite();
    this._skillNameSprite.bitmap = new Bitmap(160, 36);
    this._skillNameSprite.anchor.x = 0.5;
    this._skillNameSprite.anchor.y = 1;
    this._skillNameSprite.y = -52;
    this._skillNameSprite.visible = false;
    this._skillNameSprite._initialized = false;
    this.addChild(this._skillNameSprite);
};

Sprite_Character.prototype.refreshSkillNameText = function(text, color) {
    var bitmap = this._skillNameSprite.bitmap;
    bitmap.clear();

    bitmap.fontSize = 18;
    bitmap.textColor = color || "#66ccff";
    bitmap.outlineColor = "#000000";
    bitmap.outlineWidth = 4;

    bitmap.drawText(text, 0, 0, bitmap.width, 32, "center");
};
    //--------------------------
    // 敌人血条
    //--------------------------
    Sprite_Character.prototype.updateEnemyUI = function() {
        var char = this._character;

        if (char && char._enemyEntity && char._hp > 0) {
            if (!this._enemyBarSprite) {
                this.createEnemyBar();
            }
            this._enemyBarSprite.visible = true;
            this.refreshEnemyBar();
        } else {
            if (this._enemyBarSprite) {
                this._enemyBarSprite.visible = false;
            }
        }
    };

    Sprite_Character.prototype.createEnemyBar = function() {
        this._enemyBarSprite = new Sprite();
        this._enemyBarSprite.bitmap = new Bitmap(100, 40);
        this._enemyBarSprite.anchor.x = 0.5;
        this._enemyBarSprite.anchor.y = 1;
        this._enemyBarSprite.y = -36;
        this.addChild(this._enemyBarSprite);
        this._lastHp = -1;
    };

Sprite_Character.prototype.refreshEnemyBar = function() {
    var char = this._character;
    if (!char || !char._enemyEntity) return;

    var hp = Math.max(0, Math.floor(char._hp));
    var mhp = Math.max(1, char._enemyEntity.mhp);

    var mp = Math.max(0, Math.floor(char._enemyEntity.mp));
    var mmp = Math.max(1, char._enemyEntity.mmp);

    // HP 和 MP 都没变化时不重绘
    if (this._lastHp === hp && this._lastMp === mp) return;
    this._lastHp = hp;
    this._lastMp = mp;

    var hpRate = hp / mhp;
    var mpRate = mp / mmp;

    var bitmap = this._enemyBarSprite.bitmap;
    bitmap.clear();

    // 条宽高
    var bw = 60;
    var bh = 7;
    var bx = 22;

    // HP 条位置
    var hpBy = 0;
    // MP 条位置（在 HP 下方）
    var mpBy = 27;

    // HP 背景
    bitmap.fillRect(bx, hpBy, bw, bh, "rgba(0,0,0,0.8)");
    // HP 红条
    bitmap.fillRect(bx + 1, hpBy + 1, Math.floor((bw - 2) * hpRate), bh - 2, "#ff4444");

    // MP 背景
    //bitmap.fillRect(bx, mpBy, bw, bh, "rgba(0,0,0,0.8)");
    // MP 蓝条
    //bitmap.fillRect(bx + 1, mpBy + 1, Math.floor((bw - 2) * mpRate), bh - 2, "#4488ff");

    // 文字
    bitmap.fontSize = 10;
    bitmap.textColor = "#ffffff";
    bitmap.outlineColor = "#000000";
    bitmap.outlineWidth = 3;

    //血条数字位置
    bitmap.drawText(hp + "/" + mhp, 12, -12, bitmap.width, 32, "center");
    //bitmap.drawText(mp + "/" + mmp, 12, 12, bitmap.width, 32, "center");
};

    //--------------------------
    // 飘字显示
    //--------------------------
Sprite_Character.prototype.updateDamageText = function() {
    var char = this._character;
    if (!char) return;

    if (!char._damageTexts) char._damageTexts = [];
    if (!this._damageSprites) this._damageSprites = [];

    // 有新的伤害文字，就创建新 sprite
    while (this._damageSprites.length < char._damageTexts.length) {
        this.createDamageSprite(char._damageTexts[this._damageSprites.length]);
    }

    // 更新所有飘字
    for (var i = this._damageTextsLengthSafe(char) - 1; i >= 0; i--) {
        var data = char._damageTexts[i];
        var sprite = this._damageSprites[i];
        if (!data || !sprite) continue;

        if (!sprite._initialized) {
            this.refreshDamageText(sprite, data.text, data.color);
            sprite.visible = true;
            sprite.opacity = 255;
            sprite.y = -24 - (data.offsetY || 0);
            sprite._initialized = true;
        }

        sprite.y += data.vy;
        sprite.opacity -= 4;
        data.duration--;

        if (data.duration <= 0) {
            this.removeChild(sprite);
            this._damageSprites.splice(i, 1);
            char._damageTexts.splice(i, 1);
        }
    }
};

Sprite_Character.prototype._damageTextsLengthSafe = function(char) {
    return char && char._damageTexts ? char._damageTexts.length : 0;
};

Sprite_Character.prototype.createDamageSprite = function(data) {
    var sprite = new Sprite();
    sprite.bitmap = new Bitmap(120, 40);
    sprite.anchor.x = 0.5;
    sprite.anchor.y = 1;
    sprite.y = -24 - ((data && data.offsetY) || 0);
    sprite.visible = false;
    sprite._initialized = false;
    this.addChild(sprite);
    this._damageSprites.push(sprite);
};

Sprite_Character.prototype.refreshDamageText = function(sprite, text, color) {
    var bitmap = sprite.bitmap;
    bitmap.clear();

    if (color === "#ffff66") {
        bitmap.fontSize = 28; // 暴击
    } else {
        bitmap.fontSize = 20; // 普通
    }

    bitmap.textColor = color || "#ffffff";
    bitmap.outlineColor = "#000000";
    bitmap.outlineWidth = 4;

    bitmap.drawText(text, 0, 0, bitmap.width, 32, "center");
};

    //==================================================
