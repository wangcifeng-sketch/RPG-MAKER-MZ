Game_Event.prototype.isEnemyDead = function() {
    return !!this._enemyEntity && this._hp <= 0;
};

Game_Event.prototype.onEnemyDead = function() {
    if (this._deadProcessed) return;
    this._deadProcessed = true;

    this._hp = 0;

var store = this.ensureEnemyStateStore();
store[this.enemyStateKey()] = {
    enemyId: this._enemyId,
    hp: 0,
    mp: this._enemyEntity ? this._enemyEntity.mp : 0,
    deadProcessed: true
};

    if (this._enemyEntity && this._enemyEntity.setHp) {
        this._enemyEntity.setHp(0);
    }

    var enemyData = $dataEnemies[this._enemyId];
    if (enemyData) {
        var exp = enemyData.exp || 0;
        if (exp > 0) {
            var actor = $gameParty.leader();
            if (actor) {
                actor.gainExp(exp);
            }
        }
    }

    var keyC = [$gameMap.mapId(), this.eventId(), "C"];
    $gameSelfSwitches.setValue(keyC, true);
    if ($gameMap && $gameMap.markEnemyTargetCacheDirty) {
        $gameMap.markEnemyTargetCacheDirty();
    }
};

Game_Event.prototype.resetEnemyDeathState = function() {
    this._deadProcessed = false;

    var keyC = [$gameMap.mapId(), this.eventId(), "C"];
    $gameSelfSwitches.setValue(keyC, false);

    var keyD = [$gameMap.mapId(), this.eventId(), "D"];
    $gameSelfSwitches.setValue(keyD, false);
};

Game_Event.prototype.applyDamageToEnemy = function(value) {
    if (!this._enemyEntity) return;

    this._hp = Math.max(0, this._hp - Math.max(0, value || 0));

var store = this.ensureEnemyStateStore();
store[this.enemyStateKey()] = {
    enemyId: this._enemyId,
    hp: this._hp,
    mp: this._enemyEntity ? this._enemyEntity.mp : 0,
    deadProcessed: !!this._deadProcessed
};

    if (this.isEnemyDead()) {
        this.onEnemyDead();
    }
};

Game_Event.prototype.skillCastSeData = function(skill) {
    if (!skill) return null;

    var note = skill.note || "";

    var fullMatch = note.match(/<se:([^,>]+)\s*,\s*(\d+)\s*,\s*(\d+)\s*,\s*(-?\d+)\s*>/i);
    if (fullMatch) {
        return {
            name: String(fullMatch[1]).trim(),
            volume: Number(fullMatch[2] || 90),
            pitch: Number(fullMatch[3] || 100),
            pan: Number(fullMatch[4] || 0)
        };
    }

    var simpleMatch = note.match(/<se:([^>]+)>/i);
    if (simpleMatch) {
        return {
            name: String(simpleMatch[1]).trim(),
            volume: 90,
            pitch: 100,
            pan: 0
        };
    }

    return null;
};

Game_Event.prototype.playSkillCastSe = function(skill) {
    var se = this.skillCastSeData(skill);
    if (!se || !se.name) return false;

    AudioManager.playSe({
        name: se.name,
        volume: se.volume != null ? se.volume : 90,
        pitch: se.pitch != null ? se.pitch : 100,
        pan: se.pan != null ? se.pan : 0
    });

    return true;
};

// 为 Game_Character 增加一个智能寻路方法
Game_Character.prototype.smartMoveTowardPlayer = function() {
    var interval = Math.max(1, CF_ENEMY_SMART_MOVE_INTERVAL || 1);

    if (interval > 1) {
        if (this._cfSmartMoveThrottle == null) {
            var seed = 0;
            if (this instanceof Game_Event && this.eventId) {
                seed = this.eventId();
            }
            this._cfSmartMoveThrottle = seed % interval;
        }

        if (this._cfSmartMoveThrottle > 0) {
            this._cfSmartMoveThrottle--;
            return;
        }

        this._cfSmartMoveThrottle = interval - 1;
    }

    var px = cfEnemyCharX($gamePlayer);
    var py = cfEnemyCharY($gamePlayer);
    var sx = cfEnemyCharX(this);
    var sy = cfEnemyCharY(this);

    var offsets = [
        { x: -1.0, y: -0.5 },
        { x: -1.0, y:  0.0 },
        { x: -1.0, y:  0.5 },

        { x:  1.0, y: -0.5 },
        { x:  1.0, y:  0.0 },
        { x:  1.0, y:  0.5 },

        { x: -0.5, y: -1.0 },
        { x:  0.0, y: -1.0 },
        { x:  0.5, y: -1.0 },

        { x: -0.5, y:  1.0 },
        { x:  0.0, y:  1.0 },
        { x:  0.5, y:  1.0 }
    ];

    var alreadyFace = cfEnemyNineGridTouchNoCorner(sx, sy, px, py);

    if (alreadyFace) {
        var faceDir = cfEnemyFaceDirByContact(sx, sy, px, py);
        if (faceDir > 0) {
            this._cfMoveDir8 = faceDir;
            this.setDirection(faceDir);
        }
        return;
    }

    var candidates = [];
    for (var i = 0; i < offsets.length; i++) {
        var tx = cfEnemyRoundHalf(px + offsets[i].x);
        var ty = cfEnemyRoundHalf(py + offsets[i].y);

        if (!cfEnemyNineGridTouchNoCorner(tx, ty, px, py)) {
            continue;
        }

        if (!cfEnemyBodyPassable(tx, ty)) {
            continue;
        }

        var dx = tx - sx;
        var dy = ty - sy;
        var score = dx * dx + dy * dy;

        candidates.push({ x: tx, y: ty, score: score });
    }

    if (candidates.length <= 0) {
        var fallbackDir = this.findDirectionTo(px, py);
        if (fallbackDir > 0) {
            this.moveStraight(fallbackDir);
        }
        return;
    }

    candidates.sort(function(a, b) {
        return a.score - b.score;
    });

    var tryCount = Math.min(3, candidates.length);
    for (var j = 0; j < tryCount; j++) {
        var c = candidates[j];
        var dir = this.findDirectionTo(c.x, c.y);
        if (dir > 0) {
            this.moveStraight(dir);
            return;
        }
    }

    var direction = this.findDirectionTo(px, py);
    if (direction > 0) {
        this.moveStraight(direction);
    }
};


//=============================================================================
// CF DotMove Integration
// 直接内置 DotMoveSystem 兼容：敌人追踪、贴脸距离、远程直线距离。
//=============================================================================
var CF_ENEMY_DOTMOVE_MOVE_UNIT = Math.max(0.05, Math.min(1.0, Number(params["DotMoveEnemyMoveUnit"] || 0.5)));
var CF_ENEMY_DOTMOVE_EPS = 0.00001;
var CF_ENEMY_DOTMOVE_DIAG = Math.SQRT1_2 || (1 / Math.sqrt(2));

function cfEnemyHasDotMove(ch) {
    return typeof DotMoveSystem !== "undefined" &&
        ch &&
        typeof ch.setMoveUnit === "function" &&
        typeof ch.moveByDirection === "function" &&
        typeof ch.dotMoveToPlayer === "function";
}

function cfEnemyIsLiveDotMoveEnemy(ch) {
    return ch instanceof Game_Event && !!ch._enemyEntity && ch._hp > 0;
}

function cfEnemyDotCharX(ch) {
    if (!ch) return 0;
    if (ch._realX != null) return Number(ch._realX || 0);
    if (ch._x != null) return Number(ch._x || 0);
    return Number(ch.x || 0);
}

function cfEnemyDotCharY(ch) {
    if (!ch) return 0;
    if (ch._realY != null) return Number(ch._realY || 0);
    if (ch._y != null) return Number(ch._y || 0);
    return Number(ch.y || 0);
}

function cfEnemyDotWidth(ch) {
    if (!ch) return 1;
    if (typeof ch.width === "function") return Math.max(0.1, Number(ch.width() || 1));
    return 1;
}

function cfEnemyDotHeight(ch) {
    if (!ch) return 1;
    if (typeof ch.height === "function") return Math.max(0.1, Number(ch.height() || 1));
    return 1;
}

function cfEnemyDotCenterX(ch) {
    if (!ch) return 0;
    if (typeof ch.centerRealX === "function") return Number(ch.centerRealX() || 0);
    return cfEnemyDotCharX(ch) + cfEnemyDotWidth(ch) / 2;
}

function cfEnemyDotCenterY(ch) {
    if (!ch) return 0;
    if (typeof ch.centerRealY === "function") return Number(ch.centerRealY() || 0);
    return cfEnemyDotCharY(ch) + cfEnemyDotHeight(ch) / 2;
}

function cfEnemyDotRadius(ch) {
    return Math.max(cfEnemyDotWidth(ch), cfEnemyDotHeight(ch)) * 0.5;
}

function cfEnemyDotVectorFromDir(d) {
    switch (d) {
        case 1: return { x: -CF_ENEMY_DOTMOVE_DIAG, y:  CF_ENEMY_DOTMOVE_DIAG };
        case 2: return { x: 0,                     y:  1 };
        case 3: return { x:  CF_ENEMY_DOTMOVE_DIAG, y:  CF_ENEMY_DOTMOVE_DIAG };
        case 4: return { x: -1,                    y:  0 };
        case 6: return { x:  1,                    y:  0 };
        case 7: return { x: -CF_ENEMY_DOTMOVE_DIAG, y: -CF_ENEMY_DOTMOVE_DIAG };
        case 8: return { x: 0,                     y: -1 };
        case 9: return { x:  CF_ENEMY_DOTMOVE_DIAG, y: -CF_ENEMY_DOTMOVE_DIAG };
        default: return { x: 0, y: 0 };
    }
}

function cfEnemyDotDir8FromDelta(dx, dy) {
    var ax = Math.abs(dx);
    var ay = Math.abs(dy);
    var x = ax < 0.001 ? 0 : (dx > 0 ? 1 : -1);
    var y = ay < 0.001 ? 0 : (dy > 0 ? 1 : -1);

    if (x === -1 && y ===  1) return 1;
    if (x ===  0 && y ===  1) return 2;
    if (x ===  1 && y ===  1) return 3;
    if (x === -1 && y ===  0) return 4;
    if (x ===  1 && y ===  0) return 6;
    if (x === -1 && y === -1) return 7;
    if (x ===  0 && y === -1) return 8;
    if (x ===  1 && y === -1) return 9;
    return 0;
}

function cfEnemyDotVisualDir4FromDir8(dir8) {
    switch (dir8) {
        case 1:
        case 7:
        case 4:
            return 4;
        case 3:
        case 9:
        case 6:
            return 6;
        case 8:
            return 8;
        case 2:
            return 2;
        default:
            return 0;
    }
}

function cfEnemyDotFacePlayer(ch) {
    if (!ch || !$gamePlayer) return;
    var dx = cfEnemyDotCenterX($gamePlayer) - cfEnemyDotCenterX(ch);
    var dy = cfEnemyDotCenterY($gamePlayer) - cfEnemyDotCenterY(ch);
    var dir8 = cfEnemyDotDir8FromDelta(dx, dy);
    if (dir8 <= 0) return;

    ch._cfMoveDir8 = dir8;

    var dir4 = cfEnemyDotVisualDir4FromDir8(dir8);
    if (dir4 > 0 && typeof ch.setDirection === "function") {
        ch.setDirection(dir4);
    }
}

function cfEnemyDotDirToHV(d) {
    switch (d) {
        case 1: return [4, 2];
        case 3: return [6, 2];
        case 7: return [4, 8];
        case 9: return [6, 8];
        default: return [0, 0];
    }
}

function cfEnemyDotMapPassableAtCenter(cx, cy, d) {
    var tx = Math.floor(cx);
    var ty = Math.floor(cy);

    if (!$gameMap || !$gameMap.isValid(tx, ty)) return false;

    if (d === 1 || d === 3 || d === 7 || d === 9) {
        var hv = cfEnemyDotDirToHV(d);
        return $gameMap.isPassable(tx, ty, hv[0]) && $gameMap.isPassable(tx, ty, hv[1]);
    }

    return $gameMap.isPassable(tx, ty, d || 2);
}

function cfEnemyDotTouchRange(a, b) {
    return cfEnemyDotRadius(a) + cfEnemyDotRadius(b) + 0.08;
}

function cfEnemyDotInAttackRange(enemy, target) {
    if (!enemy || !target) return false;
    var dx = cfEnemyDotCenterX(target) - cfEnemyDotCenterX(enemy);
    var dy = cfEnemyDotCenterY(target) - cfEnemyDotCenterY(enemy);
    var range = cfEnemyDotTouchRange(enemy, target);
    return (dx * dx + dy * dy) <= range * range;
}

function cfEnemyDotPlayerTargetX() {
    return $gamePlayer && $gamePlayer._realX != null ? Number($gamePlayer._realX || 0) : ($gamePlayer ? $gamePlayer.x : 0);
}

function cfEnemyDotPlayerTargetY() {
    return $gamePlayer && $gamePlayer._realY != null ? Number($gamePlayer._realY || 0) : ($gamePlayer ? $gamePlayer.y : 0);
}

// CF 战斗逻辑用这个读取 8 方向；没有 CF_EightDirHalfStep 时也能正常工作。
if (!Game_CharacterBase.prototype.cfInteractionDirection) {
    Game_CharacterBase.prototype.cfInteractionDirection = function() {
        return this._cfMoveDir8 || this.direction();
