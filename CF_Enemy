Game_Event.prototype.attackPlayer = function() {
    if (!this._enemyEntity) return false;

    var actor = this.playerBattler();
    if (!actor) return false;

    if (this._attackCooldown == null) this._attackCooldown = 0;
    if (this._attackCooldown > 0) return false;

    // 还在移动到位时，禁止起手
    if (this.isMoving && this.isMoving()) return false;

    // 正在攻击动作/锁定中，也不要重复起手
    if (this.isEnemyAttackBusy && this.isEnemyAttackBusy()) return false;

    var action = this.selectEnemyActionByRating();
    if (!action) return false;

    var skillId = action.skillId;
    var skill = $dataSkills[skillId];
    if (!skill) return false;

    // 用当前真实位置重新朝向玩家
// 用当前真实位置重新朝向玩家
// 已经贴面时，按“贴边方向”决定；未贴面时，才按中心点方向
var dir8 = cfEnemyFaceDirByContact(
    cfEnemyCharX(this),
    cfEnemyCharY(this),
    cfEnemyCharX($gamePlayer),
    cfEnemyCharY($gamePlayer)
);

if (dir8 > 0) {
    this._cfMoveDir8 = dir8;
    this.setDirection(dir8);
}

    if (!this.canUseEnemySkillByRange(skill)) return false;

    return this.useEnemySkillOnPlayer(skillId);
};
    //==================================================
    // 12. 敌人攻击玩家（普通攻击 / 技能）
    //==================================================
Game_Event.prototype.useEnemySkillOnPlayer = function(skillId) {
    if (!this._enemyEntity) return false;

    var actor = this.playerBattler();
    if (!actor) return false;

    var skill = $dataSkills[skillId];
    if (!skill) return false;

    if (!this._enemyEntity.canPaySkillCost(skill)) {
        return false;
    }

    var motionTime = (skillId > 1 ? 50 : 30);
    var delay = Math.floor(motionTime * 0.45);

    this.startEnemyAttackMotion(motionTime);
    this.playSkillCastSe(skill);

    var isNormalAttackSkill = /<normalAttackSkill>/i.test(skill.note || "");
    if (!isNormalAttackSkill) {
        this.showSkillNameText(skill.name, "#66ccff");
    }

    this._enemyEntity.paySkillCost(skill);

    var hasAttackObject = false;
    if (this.skillAttackObjectType) {
        hasAttackObject = !!this.skillAttackObjectType(skill);
    }

    // 有攻击体：等动作+攻击体结束
    // 无攻击体：等动作+直接技能结算结束
    this.startEnemyAttackLock(hasAttackObject);

    if (hasAttackObject && this.queueEnemyAttackObject) {
        this.queueEnemyAttackObject(skill, delay);
        this._attackCooldown = (skillId > 1 ? 90 : 60);
        return true;
    }

    // 直接技能不再立刻扣血，改成延迟到出手帧再判定
    this.queueEnemyDirectSkill(skill, delay);
    this._attackCooldown = (skillId > 1 ? 90 : 60);
    return true;
};

