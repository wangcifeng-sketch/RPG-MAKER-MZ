Sprite_Character.prototype.refreshEnemyBar = function(forceRefresh) {
    var char = this._character;
    if (!char || !char._enemyEntity) return;

    var hp = Math.max(0, Math.floor(char._hp));
    var mhp = Math.max(1, char._enemyEntity.mhp);

    var mp = Math.max(0, Math.floor(char._enemyEntity.mp));
    var mmp = Math.max(1, char._enemyEntity.mmp);

    var oldHp = this._lastHp;
    var oldMp = this._lastMp;

    // 只有 HP/MP 变化，或者数字显示计时中，才重绘
    if (!forceRefresh && oldHp === hp && oldMp === mp) return;

    // 只有“掉血”时才显示数字 60 帧
    if (oldHp >= 0 && hp < oldHp) {
        this._enemyHpNumberTimer = 60;
    }

    this._lastHp = hp;
    this._lastMp = mp;

    var hpRate = hp / mhp;
    var mpRate = mp / mmp;

    var bitmap = this._enemyBarSprite.bitmap;
    bitmap.clear();

    var bw = 60;
    var bh = 7;
    var bx = 22;
    var hpBy = 0;
    var mpBy = 27;

    bitmap.fillRect(bx, hpBy, bw, bh, "rgba(0,0,0,0.8)");
    bitmap.fillRect(bx + 1, hpBy + 1, Math.floor((bw - 2) * hpRate), bh - 2, "#ff4444");

    //bitmap.fillRect(bx, mpBy, bw, bh, "rgba(0,0,0,0.8)");
    //bitmap.fillRect(bx + 1, mpBy + 1, Math.floor((bw - 2) * mpRate), bh - 2, "#4488ff");

    // 只有掉血后的计时内才显示数字
    if (this._enemyHpNumberTimer > 0) {
        bitmap.fontSize = 10;
        bitmap.textColor = "#ffffff";
        bitmap.outlineColor = "#000000";
        bitmap.outlineWidth = 3;
        bitmap.drawText(hp + "/" + mhp, 12, -12, bitmap.width, 32, "center");
    }
};

