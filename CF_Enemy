 * ● 商业使用
 * ● 商业用途需获得作者授权
 * ============================================================================
 */

(function() {

var pluginName = "CF_Enemy";
var params = PluginManager.parameters(pluginName);
var CF_ENEMY_SMART_MOVE_INTERVAL = Math.max(1, Number(params["SmartMoveInterval"] || 8));
var CF_ENEMY_DEFAULT_RESPAWN_WAIT = 6000; // 6000帧 = 100秒


    //==================================================
    // 1. 事件敌人属性初始化
    //==================================================
    var _Game_Event_setupPage = Game_Event.prototype.setupPage;
    Game_Event.prototype.setupPage = function() {
        _Game_Event_setupPage.call(this);
        this.initEnemyEntity();
    };

Game_Event.prototype.enemyStateKey = function() {
    return $gameMap.mapId() + "_" + this.eventId();
};

Game_Event.prototype.ensureEnemyStateStore = function() {
    if (!$gameSystem._cfEnemyStateStore) {
        $gameSystem._cfEnemyStateStore = {};
    }
    return $gameSystem._cfEnemyStateStore;
};


Game_Event.prototype.initEnemyEntity = function() {
    if (!this.event()) return;

    var note = this.event().note || "";
    var enemyMatch = note.match(/<enemy:(\d+)>/i);

    if (enemyMatch) {
        var enemyId = Number(enemyMatch[1]);
        var store = this.ensureEnemyStateStore();
        var key = this.enemyStateKey();
        var saved = store[key];

        // 只有第一次，或者 enemyId 变化时，才重新创建敌人实体
        if (!this._enemyEntity || this._enemyId !== enemyId) {
            this._enemyId = enemyId;
            this._enemyEntity = new Game_Enemy(enemyId, 0, 0);

            if (saved && saved.enemyId === enemyId) {
                this._hp = saved.hp != null ? saved.hp : this._enemyEntity.mhp;
                this._mp = saved.mp != null ? saved.mp : this._enemyEntity.mmp;
                this._deadProcessed = !!saved.deadProcessed;

                if (this._enemyEntity.setHp) this._enemyEntity.setHp(this._hp);
                if (this._enemyEntity.setMp) this._enemyEntity.setMp(this._mp);
            } else {
                this._hp = this._enemyEntity.mhp;
                this._mp = this._enemyEntity.mmp;
                this._deadProcessed = false;

                store[key] = {
                    enemyId: enemyId,
                    hp: this._hp,
                    mp: this._mp,
                    deadProcessed: false
                };
            }
        } else {
            if (this._hp == null) {
                if (saved && saved.enemyId === enemyId) {
                    this._hp = saved.hp != null ? saved.hp : this._enemyEntity.hp;
                    this._mp = saved.mp != null ? saved.mp : this._enemyEntity.mp;
                    this._deadProcessed = !!saved.deadProcessed;
                } else {
                    this._hp = this._enemyEntity.hp;
                    this._mp = this._enemyEntity.mp;
                }
            }

            if (this._enemyEntity.setHp) this._enemyEntity.setHp(this._hp);
            if (this._enemyEntity.setMp) this._enemyEntity.setMp(this._mp);
        }
    } else {
        this._enemyId = 0;
        this._enemyEntity = null;
        this._hp = 0;
        this._mp = 0;
        this._deadProcessed = false;
    }

    if (this._attackCooldown == null) this._attackCooldown = 0;
    if ($gameMap && $gameMap.markEnemyTargetCacheDirty) {
        $gameMap.markEnemyTargetCacheDirty();
    }
};
    //==================================================
    // 2. 敌人属性映射
    //==================================================
    Object.defineProperty(Game_Event.prototype, "atk", {
        get: function() { return this._enemyEntity ? this._enemyEntity.atk : 0; },
        configurable: true
    });

    Object.defineProperty(Game_Event.prototype, "def", {
        get: function() { return this._enemyEntity ? this._enemyEntity.def : 0; },
        configurable: true
    });

    Object.defineProperty(Game_Event.prototype, "mat", {
        get: function() { return this._enemyEntity ? this._enemyEntity.mat : 0; },
        configurable: true
    });

    Object.defineProperty(Game_Event.prototype, "mdf", {
        get: function() { return this._enemyEntity ? this._enemyEntity.mdf : 0; },
        configurable: true
    });

    Object.defineProperty(Game_Event.prototype, "agi", {
        get: function() { return this._enemyEntity ? this._enemyEntity.agi : 0; },
        configurable: true
    });

    Object.defineProperty(Game_Event.prototype, "luk", {
        get: function() { return this._enemyEntity ? this._enemyEntity.luk : 0; },
        configurable: true
    });

    Object.defineProperty(Game_Event.prototype, "hit", {
        get: function() { return this._enemyEntity ? this._enemyEntity.hit : 0; },
        configurable: true
    });

    Object.defineProperty(Game_Event.prototype, "eva", {
        get: function() { return this._enemyEntity ? this._enemyEntity.eva : 0; },
        configurable: true
    });

    Object.defineProperty(Game_Event.prototype, "cri", {
        get: function() { return this._enemyEntity ? this._enemyEntity.cri : 0; },
        configurable: true
    });

    //==================================================
    // 3. 飘字系统（MISS / 数字）
    //==================================================
Game_Character.prototype.showDamageText = function(text, color) {
    if (!this._damageTexts) this._damageTexts = [];

    this._damageTexts.push({
        text: String(text || ""),
        color: color || "#ffffff",
        duration: 60,
        vy: -1.2,
        offsetY: this._damageTexts.length * 16   // 后来的字稍微错开
    });
};

    Game_Character.prototype.showSkillNameText = function(text, color) {
        this._skillNameText = {
            text: String(text || ""),
            color: color || "#66ccff",
            duration: 45,
            vy: -0.8
        };
    };

    //==================================================
    // 4. Sprite_Character：血条 + 飘字
    //==================================================
    var _Sprite_Character_update = Sprite_Character.prototype.update;
    Sprite_Character.prototype.update = function() {
        _Sprite_Character_update.call(this);
        this.updateEnemyUI();
        this.updateDamageText();
        this.updateSkillNameText();
    };

Sprite_Character.prototype.updateSkillNameText = function() {
    var char = this._character;
    if (!char || !char._skillNameText) return;

    if (!this._skillNameSprite) {
        this.createSkillNameSprite();
    }

    var data = char._skillNameText;
    var sprite = this._skillNameSprite;

    if (!sprite._initialized) {
        this.refreshSkillNameText(data.text, data.color);
        sprite.visible = true;
        sprite.opacity = 255;
        sprite.y = -52;   // 比血条更高一点
        sprite._initialized = true;
    }

    sprite.y += data.vy;
    sprite.opacity -= 5;
    data.duration--;

    if (data.duration <= 0) {
        sprite.visible = false;
        sprite.opacity = 255;
        sprite.y = -52;
        sprite._initialized = false;
        char._skillNameText = null;
    }
};

Sprite_Character.prototype.createSkillNameSprite = function() {
    this._skillNameSprite = new Sprite();
    this._skillNameSprite.bitmap = new Bitmap(160, 36);
    this._skillNameSprite.anchor.x = 0.5;
    this._skillNameSprite.anchor.y = 1;
    this._skillNameSprite.y = -52;
    this._skillNameSprite.visible = false;
    this._skillNameSprite._initialized = false;
    this.addChild(this._skillNameSprite);
};

Sprite_Character.prototype.refreshSkillNameText = function(text, color) {
    var bitmap = this._skillNameSprite.bitmap;
    bitmap.clear();

    bitmap.fontSize = 18;
    bitmap.textColor = color || "#66ccff";
    bitmap.outlineColor = "#000000";
    bitmap.outlineWidth = 4;

    bitmap.drawText(text, 0, 0, bitmap.width, 32, "center");
};
    //--------------------------
    // 敌人血条
    //--------------------------
Sprite_Character.prototype.updateEnemyUI = function() {
    var char = this._character;

    if (char && char._enemyEntity && char._hp > 0) {
        if (!this._enemyBarSprite) {
            this.createEnemyBar();
        }
        this._enemyBarSprite.visible = true;

        var forceRefresh = false;
        if (this._enemyHpNumberTimer > 0) {
            this._enemyHpNumberTimer--;
            forceRefresh = true;
