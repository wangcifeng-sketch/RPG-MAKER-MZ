    this._enemyAttackFixedDirection = 0;

    this._respawnCountdownStarted = false;
    this._respawnCountdown = 0;
};

Game_Event.prototype.isEnemyAttackBusy = function() {
    if (this._enemyMotionPlaying) return true;
    if (this._pendingAttackObjectSkill) return true;
    if (this._pendingDirectSkill) return true;

    if (this._enemyAttackLockWaitObject) {
        if (this._enemyActiveAttackObject && !this._enemyActiveAttackObject._finished) {
            return true;
        }
    }

    return false;
};

Game_Event.prototype.startEnemyAttackLock = function(waitObject) {
    this._enemyAttackLocked = true;
    this._enemyAttackLockWaitObject = !!waitObject;
    this._enemyActiveAttackObject = null;
    this._enemyAttackFixedDirection = this.direction();
};

Game_Event.prototype.endEnemyAttackLock = function() {
    this._enemyAttackLocked = false;
    this._enemyAttackLockWaitObject = false;
    this._enemyActiveAttackObject = null;
    this._enemyAttackFixedDirection = 0;
};

var _Game_Event_setDirection_CFEnemyAttackLock = Game_Event.prototype.setDirection;
Game_Event.prototype.setDirection = function(d) {
    if (this._enemyAttackLocked) {
        if (this._enemyAttackFixedDirection > 0) {
            _Game_Event_setDirection_CFEnemyAttackLock.call(this, this._enemyAttackFixedDirection);
            return;
        }
        return;
    }
    _Game_Event_setDirection_CFEnemyAttackLock.call(this, d);
};

Game_Event.prototype.updateEnemyAttackLock = function() {
    if (!this._enemyAttackLocked) return;

    if (!this.isEnemyAttackBusy()) {
        this.endEnemyAttackLock();
    }
};

Game_Event.prototype.enemyRespawnWaitFrames = function() {
    if (!this.event()) return CF_ENEMY_DEFAULT_RESPAWN_WAIT;

    var note = this.event().note || "";
    var match = note.match(/<respawn:(\d+)>/i);

    if (match) {
        return Math.max(1, Number(match[1] || CF_ENEMY_DEFAULT_RESPAWN_WAIT));
    }

    return CF_ENEMY_DEFAULT_RESPAWN_WAIT;
};

Game_Event.prototype.isRespawnPageActive = function() {
    var keyD = [$gameMap.mapId(), this.eventId(), "D"];
    return $gameSelfSwitches.value(keyD);
};

Game_Event.prototype.resetRespawnCountdown = function() {
    this._respawnCountdownStarted = false;
    this._respawnCountdown = 0;
};

Game_Event.prototype.updateAutoRespawnCountdown = function() {
    if (!this._enemyId) return;

    if (!this.isRespawnPageActive()) {
        this.resetRespawnCountdown();
        return;
    }

    if (!this._respawnCountdownStarted) {
        this._respawnCountdownStarted = true;
        this._respawnCountdown = this.enemyRespawnWaitFrames();
    }

    if (this._respawnCountdown > 0) {
        this._respawnCountdown--;
    }

    if (this._respawnCountdown <= 0) {
        this.resetRespawnCountdown();
        this.respawnEnemy();
    }
};

// 每次刷新页面时，自动读取当前敌人的图名
var _Game_Event_setupPage_CFEnemyAttackMotion = Game_Event.prototype.setupPage;
Game_Event.prototype.setupPage = function() {
    _Game_Event_setupPage_CFEnemyAttackMotion.call(this);

    // 当前事件页使用的行走图，视为“正常图”
    this._enemyNormalCharacterName = this.characterName ? this.characterName() : "";
    this._enemyAttackCharacterName = this._enemyNormalCharacterName
        ? this._enemyNormalCharacterName + "_attack"
        : "";
};

// 播放敌人攻击动作
Game_Event.prototype.startEnemyAttackMotion = function(wait) {
    wait = wait || 18;

    if (!this._enemyNormalCharacterName) {
        this._enemyNormalCharacterName = this.characterName ? this.characterName() : "";
    }

    if (!this._enemyNormalCharacterName) return;

    this._enemyAttackCharacterName = this._enemyNormalCharacterName + "_attack";

    // 切换到攻击图
    this.setImage(this._enemyAttackCharacterName, this.characterIndex());

    // ⭐ 关键：强制从左边第1帧开始
    this._pattern = 0;

    this._enemyAttackMotionWait = wait;
    this._enemyAttackMotionTotal = wait;
    this._enemyMotionPlaying = true;
};

Game_Event.prototype.updateEnemyAttackMotionPattern = function() {
    if (!this._enemyMotionPlaying) return;

    var total = Math.max(1, this._enemyAttackMotionTotal || 1);
    var left = Math.max(0, this._enemyAttackMotionWait || 0);
    var passed = total - left;

    // 1 -> 2 -> 3 （左到右）
    if (passed < total / 3) {
        this._pattern = 0;   // 第1帧（左）
    } else if (passed < total * 2 / 3) {
        this._pattern = 1;   // 第2帧（中）
    } else {
        this._pattern = 2;   // 第3帧（右）
    }
};

// 结束敌人攻击动作
Game_Event.prototype.endEnemyAttackMotion = function() {
    if (!this._enemyNormalCharacterName) return;

    this.setImage(this._enemyNormalCharacterName, this.characterIndex());
    this._enemyAttackMotionWait = 0;
    this._enemyAttackMotionTotal = 0;
    this._enemyMotionPlaying = false;

    // 恢复站立帧
    this._pattern = 1;
};

// 更新攻击动作计时
var _Game_Event_update_CFEnemyAttackMotion = Game_Event.prototype.update;
Game_Event.prototype.update = function() {
    _Game_Event_update_CFEnemyAttackMotion.call(this);

    if (this._enemyMotionPlaying) {
        this.updateEnemyAttackMotionPattern();

        if (this._enemyAttackMotionWait > 0) {
            this._enemyAttackMotionWait--;
        }

        if (this._enemyAttackMotionWait <= 0) {
            this.endEnemyAttackMotion();
        }
    }

    this.updateQueuedAttackObject();
    this.updateQueuedDirectSkill();
    this.updateEnemyAttackLock();
    this.updateAutoRespawnCountdown();
};

var _Game_Event_moveStraight_CFEnemyAttackLock = Game_Event.prototype.moveStraight;
Game_Event.prototype.moveStraight = function(d) {
    if (this._enemyAttackLocked) {
        this.setMovementSuccess(false);
        return;
    }
    _Game_Event_moveStraight_CFEnemyAttackLock.call(this, d);
};

var _Game_Event_moveDiagonally_CFEnemyAttackLock = Game_Event.prototype.moveDiagonally;
Game_Event.prototype.moveDiagonally = function(horz, vert) {
    if (this._enemyAttackLocked) {
        this.setMovementSuccess(false);
        return;
    }
    _Game_Event_moveDiagonally_CFEnemyAttackLock.call(this, horz, vert);
};

Game_Event.prototype.isPlayerInAttackRange = function() {
    // 近战开打条件：敌人本体必须已经和玩家贴面
    // 不能“隔着半步”就开始
    return cfEnemyNineGridTouchNoCorner(
        cfEnemyCharX(this),
        cfEnemyCharY(this),
        cfEnemyCharX($gamePlayer),
        cfEnemyCharY($gamePlayer)
    );
};

Game_Event.prototype.isPlayerCollidedForAttack = function() {
    return this.isPlayerInAttackRange();
};

Game_Event.prototype.enemySkillRange = function(skill) {
    if (!skill) return 1;

    var note = skill.note || "";
    var match = note.match(/<range:(\d+)>/i);

    if (match) {
        return Math.max(1, Number(match[1]));
    }

    // 没写的话默认 1 格
    return 1;
};

Game_Event.prototype.canUseEnemySkillByRange = function(skill) {
    var range = this.enemySkillRange(skill);

    // 近战/贴脸技能：必须已经贴面才允许起手
    if (range <= 1) {
        return this.isPlayerInAttackRange();
    }

    // 远程/更长距离技能：继续走半步八方向直线判定
    return this.isPlayerInLineRange(range);
};

Game_Event.prototype.isPlayerInLineRange = function(range) {
    range = Math.max(1, range || 1);

    var dir = cfEnemyFacingDir8(this);
    var vec = cfEnemyVectorFromDir(dir);

    var x = cfEnemyCharX(this);
    var y = cfEnemyCharY(this);

    var steps = range * 2; // 技能配置仍按“格”，内部按“半步”检查

    for (var i = 1; i <= steps; i++) {
        x = cfEnemyRoundHalf(x + vec.x * CF_ENEMY_HALF_STEP);
        y = cfEnemyRoundHalf(y + vec.y * CF_ENEMY_HALF_STEP);

        // 路上被墙挡住就不能打
        if (!cfEnemyBodyPassable(x, y)) {
            return false;
        }

        if (cfEnemyNineGridTouchNoCorner(
            x, y,
            cfEnemyCharX($gamePlayer),
            cfEnemyCharY($gamePlayer)
        )) {
            return true;
        }
    }

    return false;
};

Game_Event.prototype.queueEnemyDirectSkill = function(skill, delay) {
    if (!skill) return false;

    this._pendingDirectSkill = skill;
    this._pendingDirectSkillDelay = Math.max(0, delay || 0);
    return true;
};

Game_Event.prototype.queueEnemyAttackObject = function(skill, delay) {
    if (!skill) return false;

    this._pendingAttackObjectSkill = skill;
    this._pendingAttackObjectDelay = Math.max(0, delay || 0);
    return true;
};

Game_Event.prototype.updateQueuedDirectSkill = function() {
    if (!this._pendingDirectSkill) return;

    if (this._pendingDirectSkillDelay > 0) {
        this._pendingDirectSkillDelay--;
        return;
    }

    var skill = this._pendingDirectSkill;
    this._pendingDirectSkill = null;
    this._pendingDirectSkillDelay = 0;

    var actor = this.playerBattler();
    if (!actor || !skill) return;

    // 到真正出手帧时，再判一次：玩家现在还在不在攻击范围内
    if (!this.canUseEnemySkillByRange(skill)) {
        return;
    }

    var result = this.calcSkillDamageToPlayer(skill);
    if (!result) return;

    if (result.missed) {
        $gamePlayer.showDamageText("MISS", "#ffffff");
        return;
    }

    actor.gainHp(-result.damage);

    if (result.critical) {
        $gamePlayer.showDamageText(String(result.damage), "#ffff66");
    } else {
        $gamePlayer.showDamageText(String(result.damage), "#ff6666");
    }
};

Game_Event.prototype.updateQueuedAttackObject = function() {
    if (!this._pendingAttackObjectSkill) return;

    if (this._pendingAttackObjectDelay > 0) {
        this._pendingAttackObjectDelay--;
        return;
    }

    var skill = this._pendingAttackObjectSkill;
    this._pendingAttackObjectSkill = null;
    this._pendingAttackObjectDelay = 0;

    if (this.spawnEnemySkillAttackObject) {
        this._enemyActiveAttackObject = this.spawnEnemySkillAttackObject(skill);
    }
};

