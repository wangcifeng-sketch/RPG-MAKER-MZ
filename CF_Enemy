        var horizontalTouch = gx <= CF_SEAM_CONTACT_GAP && oy > CF_SEAM_MIN_OVERLAP;

        if (verticalTouch && !horizontalTouch) {
            return { ok: true, dir: dy >= 0 ? 2 : 8, kind: "vertical" };
        }

        if (horizontalTouch && !verticalTouch) {
            return { ok: true, dir: dx >= 0 ? 6 : 4, kind: "horizontal" };
        }

        if (verticalTouch && horizontalTouch) {
            // If bodies overlap on both axes, pick the stronger center separation.
            // This keeps standing on a seam stable: dx near 0, dy non-zero => up/down.
            if (Math.abs(dy) >= Math.abs(dx)) {
                return { ok: true, dir: dy >= 0 ? 2 : 8, kind: "vertical-overlap" };
            }
            return { ok: true, dir: dx >= 0 ? 6 : 4, kind: "horizontal-overlap" };
