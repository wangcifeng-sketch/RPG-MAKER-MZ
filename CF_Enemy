var CF_ENEMY_EPS = 0.00001;
var CF_ENEMY_HALF_STEP = 0.5;

function cfEnemyRoundHalf(n) {
    return Math.round(Number(n || 0) * 2) / 2;
}

function cfEnemyNear(a, b, range) {
    return Math.abs(a - b) <= (range || CF_ENEMY_EPS);
}

function cfEnemyVectorFromDir(d) {
    switch (d) {
        case 1: return { x: -1, y:  1 };
        case 2: return { x:  0, y:  1 };
        case 3: return { x:  1, y:  1 };
        case 4: return { x: -1, y:  0 };
        case 6: return { x:  1, y:  0 };
        case 7: return { x: -1, y: -1 };
        case 8: return { x:  0, y: -1 };
        case 9: return { x:  1, y: -1 };
        default: return { x: 0, y: 0 };
    }
}

function cfEnemyDirToHV(d) {
    switch (d) {
        case 1: return [4, 2];
        case 3: return [6, 2];
        case 7: return [4, 8];
        case 9: return [6, 8];
        default: return [0, 0];
    }
}

function cfEnemyCharX(ch) {
    if (!ch) return 0;

    // 移动中优先用真实坐标，避免“还没走到位就先攻击”
    if (ch.isMoving && ch.isMoving() && ch._realX != null) {
        return cfEnemyRoundHalf(ch._realX);
    }

    if (typeof ch.cfHalfX === "function") return cfEnemyRoundHalf(ch.cfHalfX());
    if (ch._x != null) return cfEnemyRoundHalf(ch._x);
    return cfEnemyRoundHalf(ch.x || 0);
}

function cfEnemyCharY(ch) {
    if (!ch) return 0;

    // 移动中优先用真实坐标，避免“还没走到位就先攻击”
    if (ch.isMoving && ch.isMoving() && ch._realY != null) {
        return cfEnemyRoundHalf(ch._realY);
    }

    if (typeof ch.cfHalfY === "function") return cfEnemyRoundHalf(ch.cfHalfY());
    if (ch._y != null) return cfEnemyRoundHalf(ch._y);
    return cfEnemyRoundHalf(ch.y || 0);
}

function cfEnemyFacingDir8(ch) {
    if (!ch) return 0;
    if (typeof ch.cfInteractionDirection === "function") {
        return ch.cfInteractionDirection();
    }
    return ch.direction ? ch.direction() : 0;
}

function cfEnemyDirBetweenHalfPos(fromX, fromY, toX, toY) {
    var dx = cfEnemyNear(toX, fromX) ? 0 : (toX > fromX ? 1 : -1);
    var dy = cfEnemyNear(toY, fromY) ? 0 : (toY > fromY ? 1 : -1);

    if (dx === -1 && dy ===  1) return 1;
    if (dx ===  0 && dy ===  1) return 2;
    if (dx ===  1 && dy ===  1) return 3;
    if (dx === -1 && dy ===  0) return 4;
    if (dx ===  1 && dy ===  0) return 6;
    if (dx === -1 && dy === -1) return 7;
    if (dx ===  0 && dy === -1) return 8;
    if (dx ===  1 && dy === -1) return 9;
    return 0;
}

function cfEnemyFaceDirByContact(fromX, fromY, toX, toY) {
    fromX = cfEnemyRoundHalf(fromX);
    fromY = cfEnemyRoundHalf(fromY);
    toX = cfEnemyRoundHalf(toX);
    toY = cfEnemyRoundHalf(toY);

    var dx = toX - fromX;
    var dy = toY - fromY;

    // 左右边贴面：|dx| = 1，且另一轴只是偏移，不是纯角
    if (cfEnemyNear(Math.abs(dx), 1.0) && Math.abs(dy) < 1.0 - CF_ENEMY_EPS) {
        return dx > 0 ? 6 : 4;
    }

    // 上下边贴面：|dy| = 1，且另一轴只是偏移，不是纯角
    if (cfEnemyNear(Math.abs(dy), 1.0) && Math.abs(dx) < 1.0 - CF_ENEMY_EPS) {
        return dy > 0 ? 2 : 8;
    }

    // 不是贴面时，退回旧的中心点方向
    return cfEnemyDirBetweenHalfPos(fromX, fromY, toX, toY);
}

function cfEnemyFrontPoint(ch, dist) {
    var dir = cfEnemyFacingDir8(ch);
    var vec = cfEnemyVectorFromDir(dir);
    var step = dist != null ? dist : CF_ENEMY_HALF_STEP;

    return {
        x: cfEnemyRoundHalf(cfEnemyCharX(ch) + vec.x * step),
        y: cfEnemyRoundHalf(cfEnemyCharY(ch) + vec.y * step)
    };
}

// 九宫接触：允许贴边，不允许纯斜角
function cfEnemyNineGridTouchNoCorner(x1, y1, x2, y2) {
    var dx = Math.abs(cfEnemyRoundHalf(x1) - cfEnemyRoundHalf(x2));
    var dy = Math.abs(cfEnemyRoundHalf(y1) - cfEnemyRoundHalf(y2));

    if (dx > 1.0 + CF_ENEMY_EPS || dy > 1.0 + CF_ENEMY_EPS) {
        return false;
    }

    if (cfEnemyNear(dx, 1.0) && cfEnemyNear(dy, 1.0)) {
        return false;
    }

    return true;
}

function cfEnemyAddTileUnique(list, x, y) {
    var key = x + "," + y;
    for (var i = 0; i < list.length; i++) {
        if (list[i].key === key) return;
    }
    list.push({ key: key, x: x, y: y });
}

function cfEnemySampleTilesForBody(x, y) {
    var rx = cfEnemyRoundHalf(x);
    var ry = cfEnemyRoundHalf(y);

    var left = Math.floor(rx + CF_ENEMY_EPS);
    var right = Math.ceil(rx - CF_ENEMY_EPS);
    var top = Math.floor(ry + CF_ENEMY_EPS);
    var bottom = Math.ceil(ry - CF_ENEMY_EPS);

    var result = [];
    cfEnemyAddTileUnique(result, left, top);
    cfEnemyAddTileUnique(result, left, bottom);
    cfEnemyAddTileUnique(result, right, top);
    cfEnemyAddTileUnique(result, right, bottom);
    return result;
}

function cfEnemyBodyPassable(x, y) {
    var tiles = cfEnemySampleTilesForBody(x, y);

    for (var i = 0; i < tiles.length; i++) {
        var tx = tiles[i].x;
        var ty = tiles[i].y;

        if (!$gameMap.isValid(tx, ty)) return false;

        var passable =
            $gameMap.isPassable(tx, ty, 2) ||
            $gameMap.isPassable(tx, ty, 4) ||
            $gameMap.isPassable(tx, ty, 6) ||
            $gameMap.isPassable(tx, ty, 8);

        if (!passable) return false;
    }

    return true;
}
