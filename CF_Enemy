    Game_Event.prototype.calcAttackPlayerDamage = function() {
        if (!this._enemyEntity) return 0;

        var actor = this.playerBattler();
        if (!actor) return 0;

        var enemy = this._enemyEntity;

        var hitRate = enemy.hit || 0.95;
        var evaRate = actor.eva || 0.05;
        var finalHit = Math.max(0.05, hitRate - evaRate);

        if (Math.random() > finalHit) {
            return 0;
        }

        var baseDamage = enemy.atk - actor.def * 0.5;
        baseDamage = Math.max(1, Math.floor(baseDamage));

        if (Math.random() < (enemy.cri || 0)) {
            baseDamage = Math.floor(baseDamage * 1.5);
        }

        var variance = 0.85 + Math.random() * 0.30;
        var damage = Math.floor(baseDamage * variance);

        return Math.max(1, damage);
    };

    //==================================================
    // 9. 从数据库敌人行动中取可用技能
    //==================================================
Game_Event.prototype.selectEnemyActionByRating = function() {
    if (!this._enemyEntity || !this._enemyEntity.enemy()) return null;

    var enemyData = this._enemyEntity.enemy();
    var actions = enemyData.actions || [];
    var validActions = [];

    for (var i = 0; i < actions.length; i++) {
        var action = actions[i];
        if (!action) continue;
        if (!action.skillId || action.skillId <= 0) continue;

        var skill = $dataSkills[action.skillId];
        if (!skill) continue;

        // 数据库里的行动条件必须成立
        if (!this._enemyEntity.isActionValid(action)) continue;

        // MP / TP 消耗必须付得起
        if (!this._enemyEntity.canPaySkillCost(skill)) continue;

        validActions.push(action);
    }

    if (validActions.length === 0) return null;

    // 模拟 RPG Maker 默认敌人行动 rating 逻辑
    var maxRating = 0;
    for (var i = 0; i < validActions.length; i++) {
        if (validActions[i].rating > maxRating) {
            maxRating = validActions[i].rating;
        }
    }

    var ratingZero = maxRating - 3;
    var filtered = [];
    var sum = 0;

    for (var i = 0; i < validActions.length; i++) {
        var action = validActions[i];
        if (action.rating > ratingZero) {
            filtered.push(action);
            sum += action.rating - ratingZero;
        }
    }

    if (filtered.length === 0 || sum <= 0) return null;

    var value = Math.random() * sum;

    for (var i = 0; i < filtered.length; i++) {
        var action = filtered[i];
        value -= (action.rating - ratingZero);
        if (value < 0) {
            return action;
        }
    }

    return filtered[0];
};

    //==================================================
    // 10. 技能伤害计算（按数据库技能公式）
    //==================================================
    Game_Event.prototype.calcSkillDamageToPlayer = function(skill) {
        if (!this._enemyEntity || !skill) return null;

        var actor = this.playerBattler();
        if (!actor) return null;

        var enemy = this._enemyEntity;

        var successRate = (skill.successRate != null ? skill.successRate : 100) / 100;
        var hitChance = successRate * (enemy.hit || 0.95);
        var evaRate = actor.eva || 0.05;
        var finalHit = Math.max(0.05, hitChance - evaRate);

        if (Math.random() > finalHit) {
            return {
                missed: true,
                damage: 0,
                critical: false
            };
        }

        var damage = 0;
        var critical = false;

        if (skill.damage && skill.damage.type > 0) {
            var a = enemy;
            var b = actor;
            var v = $gameVariables._data;

            try {
                damage = Math.floor(eval(skill.damage.formula || "0"));
            } catch (e) {
                damage = 0;
            }

            // 只对 HP伤害 允许暴击
            if (skill.damage.type === 1) {
                critical = Math.random() < (enemy.cri || 0);
                if (critical) {
                    damage = Math.floor(damage * 1.5);
                }
            }

            var variance = skill.damage.variance || 0;
            if (variance > 0) {
                var amp = Math.floor(Math.abs(damage) * variance / 100);
                damage += Math.floor(Math.random() * (amp * 2 + 1)) - amp;
            }

            // 1 = HP伤害
            // 3 = HP恢复
            if (skill.damage.type === 1) {
                damage = Math.max(0, damage);
            } else if (skill.damage.type === 3) {
                damage = -Math.max(0, damage);
            } else {
                damage = 0;
            }
        }

        return {
            missed: false,
            damage: damage,
            critical: critical
        };
    };

