Game_Event.prototype.respawnEnemy = function() {
    if (!this._enemyId) return;

    var enemyData = $dataEnemies[this._enemyId];
    if (!enemyData) return;

    this.resetEnemyDeathState();

    var battler = new Game_Enemy(this._enemyId, 0, 0);

    this._enemyEntity = battler;
    this._hp = battler.mhp;
    this._mp = battler.mmp;
    this.resetRespawnCountdown();

    var store = this.ensureEnemyStateStore();
    store[this.enemyStateKey()] = {
        enemyId: this._enemyId,
        hp: this._hp,
        mp: this._mp,
        deadProcessed: false
    };

    var keyD = [$gameMap.mapId(), this.eventId(), "D"];
    $gameSelfSwitches.setValue(keyD, false);

    if (this.refreshEnemyBar) {
        this.refreshEnemyBar();
    }

    this.refresh();
    if ($gameMap && $gameMap.markEnemyTargetCacheDirty) {
        $gameMap.markEnemyTargetCacheDirty();
    }
};

Game_Event.prototype.updateRegen = function() {
    if (!this._enemyEntity || this._hp <= 0) return;

    if (this._regenTick == null) this._regenTick = 0;

    this._regenTick++;

    // 每60帧（1秒）
    if (this._regenTick >= 120) {
        this._regenTick = 0;

        var enemy = this._enemyEntity;

        // ===== HP恢复 =====
        var mhp = enemy.mhp;
        var hpRegen = Math.max(1, Math.floor(mhp * 0.0002)); // 0.1%

        this._hp = Math.min(this._hp + hpRegen, mhp);

        // ===== MP恢复 =====
        var mmp = enemy.mmp;
        var mpRegen = Math.max(1, Math.floor(mmp * 0.00015));

        enemy.gainMp(mpRegen);
    }
};
