/*:
 * @target MZ
 * @plugindesc 暗器系统（S键发射 / 支持双武器槽 / 武器类型3 / 数量按实际持有武器计算 / 技能12统一伤害与动画 / UI / 独立飞行体）
 * @author ChatGPT
 *
 * @param WindowX
 * @text UI X坐标
 * @type number
 * @default 840
 *
 * @param WindowY
 * @text UI Y坐标
 * @type number
 * @default 621
 *
 * @param EmptySlotVisible
 * @text 0数量时显示空槽
 * @type boolean
 * @on 显示
 * @off 隐藏
 * @default true
 *
 * @param FireSe
 * @text 发射音效
 * @type file
 * @dir audio/se/
 * @default Sword2
 *
 * @param EmptySe
 * @text 空仓音效
 * @type file
 * @dir audio/se/
 * @default Buzzer1
 *
 * @help
 * =============================================================================
 * ■ 插件功能
 * =============================================================================
 * 在地图界面按【S键】发射暗器。
 *
 * 规则：
 * 1. 当前角色装备中，必须存在【武器类型 = 3】的武器
 * 2. 队伍中必须实际持有该暗器武器至少 1 个
 * 3. 满足冷却条件
 *
 * 本插件的数量逻辑为：
 * - 数量直接读取“队伍持有的该武器数量”
 * - 不再使用变量作为暗器数量
 * - 发射一次会自动消耗 1 个该暗器武器
 *
 * 说明：
 * 本插件支持通过职业备注自定义装备槽，例如：
 *
 * <equipSlots:1,1,2,3,4,5,6>
 *
 * 当职业有两个武器槽时，本插件会自动在所有装备槽里查找
 * “武器类型 = 3”的武器作为暗器。
 *
 * =============================================================================
 * ■ 素材
 * =============================================================================
 * 暗器素材文件：
 *
 * img/characters/Hidden_Weapon.png
 *
 * HiddenWeaponIndex 对应 0~7。
 *
 * =============================================================================
 * ■ 武器备注
 * =============================================================================
 * 在暗器武器备注中写：
 *
 * <HiddenWeaponIndex: 0>
 * <HiddenWeaponSpeed: 6>
 * <HiddenWeaponRange: 8>
 * <HiddenWeaponCooldown: 12>
 *
 * -----------------------------------------------------------------------------
 * 参数说明
 * -----------------------------------------------------------------------------
 *
 * HiddenWeaponIndex
 * - 暗器图索引（0~7）
 *
 * HiddenWeaponSpeed
 * - 飞行速度
 * - 默认 6
 *
 * HiddenWeaponRange
 * - 飞行距离（格）
 * - 默认 8
 *
 * HiddenWeaponCooldown
 * - 发射冷却（帧）
 * - 默认 12
 *
 * =============================================================================
 * ■ 伤害规则
 * =============================================================================
 * 暗器伤害统一使用技能 ID 12 的设置。
 *
 * 也就是说，下面这些内容都以技能12为准：
 * - 伤害类型
 * - 伤害公式
 * - 波动
 * - 会心
 * - 命中动画
 *
 * 因此武器备注中不再需要写：
 *
 * <HiddenWeaponDamageType:x>
 * <HiddenWeaponFormula:xxx>
 * <HiddenWeaponVariance:x>
 * <HiddenWeaponCritical:true/false>
 * <HiddenWeaponAnimation:x>
 *
 * 请直接在数据库中配置技能12的伤害和动画。
 *
 * =============================================================================
 * ■ 数量规则
 * =============================================================================
 * 每次发射：
 * - 自动消耗队伍中 1 个当前装备的暗器武器
 *
 * 数量 = 0 时：
 * - 不能发射
 * - 暗器槽为空或显示空槽（取决于参数）
 *
 * 注意：
 * 数量不是变量，不需要写：
 * <HiddenWeaponCountVar:x>
 * <HiddenWeaponInitCount:x>
 *
 * 现在数量由下面这条决定：
 * - 背包中的该暗器武器数量
 * - 加上全队已装备的同ID暗器数量
 *
 * 例如：
 * 当前装备的暗器武器ID为 15
 * 背包中有 9 个，角色身上装备了 1 个
 * 则 UI 显示 x10
 * 发射一次后变为 x9
 *
 * =============================================================================
 * ■ 按键
 * =============================================================================
 * S键发射暗器
 *
 * =============================================================================
 * ■ 推荐搭配
 * =============================================================================
 * 本插件适配“职业备注改装备槽”的写法，例如：
 * <equipSlots:1,1,2,3,4,5,6>
 *
 * 地图敌人命中逻辑适配如下结构：
 * - 敌人事件使用 _enemyEntity
 * - 敌人血量使用 _hp
 *
 * =============================================================================
 * ■ 重要说明
 * =============================================================================
 * 1. 暗器必须是武器，并且武器类型必须为 3
 * 2. 暗器要真实存在于队伍物品栏中，数量才会显示并可发射
 * 3. 本插件不会自动补充暗器数量
 * 4. 想增加暗器，请直接通过事件“增减武器”来获得对应暗器武器
 * 5. 暗器伤害与命中动画统一由技能12决定
 * =============================================================================
 */

(() => {
    "use strict";

    const pluginName = "CF_HiddenWeapon";
    const params = PluginManager.parameters(pluginName);

    const WINDOW_X = Number(params["WindowX"] || 840);
    const WINDOW_Y = Number(params["WindowY"] || 621);
    const EMPTY_SLOT_VISIBLE = String(params["EmptySlotVisible"] || "true") === "true";
    const FIRE_SE = String(params["FireSe"] || "Sword2");
    const EMPTY_SE = String(params["EmptySe"] || "Buzzer1");

    const SLOT_SIZE = 32;
    const SLOT_RADIUS = 6;
    const WINDOW_WIDTH = 56;
    const WINDOW_HEIGHT = 72;

    const HIDDEN_KEY_NAME = "S";
    const HIDDEN_INPUT_SYMBOL = "hidden_weapon";
    const HIDDEN_SKILL_ID = 12;

    Input.keyMapper[83] = HIDDEN_INPUT_SYMBOL; // S键

    function getLeader() {
        return $gameParty ? $gameParty.leader() : null;
    }

    function hiddenWeaponSkill() {
        return $dataSkills[HIDDEN_SKILL_ID] || null;
    }

    function metaValue(obj, tag) {
        if (!obj) return null;
        if (obj.meta && obj.meta[tag] != null) return obj.meta[tag];
        const note = obj.note || "";
        const match = note.match(new RegExp(`<${tag}:(.*?)>`, "i"));
        return match ? String(match[1]).trim() : null;
    }

    function metaNumber(obj, tag, defaultValue) {
        const value = metaValue(obj, tag);
        if (value == null || value === "") return defaultValue;
        const num = Number(value);
        return Number.isNaN(num) ? defaultValue : num;
    }

    function findEquippedHiddenWeapon(actor) {
        if (!actor || !actor.equips) {
            return null;
        }

        const equips = actor.equips();

        for (let i = 0; i < equips.length; i++) {
            const item = equips[i];
            if (!item) continue;

            if (DataManager.isWeapon(item) && Number(item.wtypeId) === 3) {
                return item;
            }
        }

        return null;
    }

function equippedHiddenWeaponCount(weapon) {
    if (!weapon || !$gameParty) return 0;

    let count = 0;
    const members = $gameParty.members();

    for (let i = 0; i < members.length; i++) {
        const actor = members[i];
        if (!actor || !actor.equips) continue;

        const equips = actor.equips();
        for (let j = 0; j < equips.length; j++) {
            const item = equips[j];
            if (item && DataManager.isWeapon(item) && item.id === weapon.id) {
                count++;
            }
        }
    }

    return count;
}

function hiddenWeaponCount(weapon) {
    if (!weapon || !$gameParty) return 0;

    const bagCount = Math.max(0, Number($gameParty.numItems(weapon) || 0));
    const equipCount = equippedHiddenWeaponCount(weapon);

    return bagCount + equipCount;
}

function consumeHiddenWeapon(actor, weapon, amount = 1) {
    if (!weapon || !$gameParty) return false;

    let need = Math.max(1, amount);

    while (need > 0) {
        const bagCount = Math.max(0, Number($gameParty.numItems(weapon) || 0));

        // 先扣背包
        if (bagCount > 0) {
            $gameParty.loseItem(weapon, 1, false);
            need--;
            continue;
        }

        // 背包没了，再扣当前角色装备中的最后一个
        let consumedFromEquip = false;

        if (actor && actor.equips) {
            const equips = actor.equips();

            for (let slotId = 0; slotId < equips.length; slotId++) {
                const item = equips[slotId];
                if (item && DataManager.isWeapon(item) && item.id === weapon.id) {
                    // 先正常卸下（这一步会把武器退回背包）
                    actor.changeEquip(slotId, null);

                    // 再立刻从背包扣掉这 1 个，等于真正消耗掉
                    $gameParty.loseItem(weapon, 1, false);

                    need--;
                    consumedFromEquip = true;
                    break;
                }
            }
        }

        if (consumedFromEquip) {
            continue;
        }

        // 没有可消耗的了
        return false;
    }

    return true;
}

    function canUseHiddenWeapon(actor, weapon) {
        if (!actor || !weapon) return false;
        return hiddenWeaponCount(weapon) > 0;
    }

    function weaponIndex(weapon) {
        return Math.max(0, Math.min(7, metaNumber(weapon, "HiddenWeaponIndex", 0)));
    }

    function weaponSpeed(weapon) {
        return Math.max(1, metaNumber(weapon, "HiddenWeaponSpeed", 6));
    }

    function weaponRange(weapon) {
        return Math.max(1, metaNumber(weapon, "HiddenWeaponRange", 8));
    }

    function weaponCooldown(weapon) {
        return Math.max(1, metaNumber(weapon, "HiddenWeaponCooldown", 12));
    }

    function weaponHitAnimation() {
        const skill = hiddenWeaponSkill();
        if (!skill) return 0;
        return Math.max(0, Number(skill.animationId || 0));
    }

    function leaderDirectionVector() {
        const dir = $gamePlayer.direction();
        if (dir === 2) return { dx: 0, dy: 1 };
        if (dir === 4) return { dx: -1, dy: 0 };
        if (dir === 6) return { dx: 1, dy: 0 };
        return { dx: 0, dy: -1 };
    }

    function playSe(name) {
        if (!name) return;
        AudioManager.playSe({
            name: name,
            volume: 90,
            pitch: 100,
            pan: 0
        });
    }

    function buildWeaponDamageData() {
        const skill = hiddenWeaponSkill();

        if (!skill || !skill.damage) {
            return {
                type: 0,
                formula: "0",
                variance: 0,
                allowCritical: false
            };
        }

        return {
            type: Number(skill.damage.type || 0),
            formula: String(skill.damage.formula || "0"),
            variance: Number(skill.damage.variance || 0),
            allowCritical: true
        };
    }

    function applyVariance(value, variance) {
        const amp = Math.floor(Math.abs(value) * variance / 100);
        return value + Math.floor(Math.random() * (amp * 2 + 1)) - amp;
    }

    function calcHiddenWeaponDamage(actor, enemyEvent, weapon) {
        if (!actor || !enemyEvent || !weapon) {
            return { missed: true, damage: 0, critical: false };
        }

        const enemyBattler = enemyEvent._enemyEntity || null;
        if (!enemyBattler) {
            return { missed: true, damage: 0, critical: false };
        }

        const data = buildWeaponDamageData();

        let damage = 0;
        let critical = false;

        const a = actor;
        const b = enemyBattler;
        const v = $gameVariables._data;

        try {
            damage = Math.floor(eval(data.formula || "0"));
        } catch (e) {
            console.error("[CF_HiddenWeapon] 技能12伤害公式错误:", e);
            damage = 0;
        }

        if (data.type === 1 && data.allowCritical) {
            const cri = Number(actor.cri || 0);
            if (Math.random() < cri) {
                critical = true;
                damage = Math.floor(damage * 1.5);
            }
        }

        if (data.variance > 0) {
            damage = applyVariance(damage, data.variance);
        }

        if (data.type === 1) {
            damage = Math.max(0, damage);
        } else if (data.type === 3) {
            damage = -Math.max(0, damage);
        } else {
            damage = 0;
        }

        return {
            missed: false,
            damage: damage,
            critical: critical
        };
    }

function applyHiddenWeaponResult(actor, enemyEvent, weapon, result) {
    if (!enemyEvent || !result) return;

    const enemyBattler = enemyEvent._enemyEntity || null;
    if (!enemyBattler) return;

    const animId = weaponHitAnimation();
    if (animId > 0) {
        $gameTemp.requestAnimation([enemyEvent], animId);
    }

    if (result.missed) {
        if (enemyEvent.showDamageText) {
            enemyEvent.showDamageText("MISS", "#aaaaaa");
        }
        SoundManager.playMiss();
        return;
    }

    if (result.damage > 0) {
        enemyEvent._hp = Math.max(0, Math.floor(enemyEvent._hp - result.damage));

        if (enemyEvent._enemyEntity.setHp) {
            enemyEvent._enemyEntity.setHp(enemyEvent._hp);
        }

        if (enemyEvent.showDamageText) {
            enemyEvent.showDamageText(
                String(result.damage),
                result.critical ? "#ffff66" : "#ffffff"
            );
        }
    } else if (result.damage < 0) {
        const heal = -result.damage;
        const mhp = Math.max(1, enemyBattler.mhp || enemyEvent._hp || 1);

        enemyEvent._hp = Math.min(mhp, Math.floor(enemyEvent._hp + heal));

        if (enemyEvent._enemyEntity.setHp) {
            enemyEvent._enemyEntity.setHp(enemyEvent._hp);
        }

        if (enemyEvent.showDamageText) {
            enemyEvent.showDamageText(String(heal), "#66ff99");
        }
    } else {
        if (enemyEvent.showDamageText) {
            enemyEvent.showDamageText("0", "#ffffff");
        }
    }

    if (enemyEvent._hp <= 0) {
        enemyEvent._hp = 0;

        if (enemyEvent._enemyEntity.setHp) {
            enemyEvent._enemyEntity.setHp(0);
        }

        const enemyData = $dataEnemies[enemyEvent._enemyId];
        if (enemyData) {
            const exp = enemyData.exp || 0;
            if (exp > 0) {
                const leader = $gameParty.leader();
                if (leader) {
                    leader.gainExp(exp);
                }
            }
        }

        const key = [$gameMap.mapId(), enemyEvent.eventId(), "C"];
        $gameSelfSwitches.setValue(key, true);
    }
}
    const _Game_Player_initMembers_CFHiddenWeapon = Game_Player.prototype.initMembers;
    Game_Player.prototype.initMembers = function() {
        _Game_Player_initMembers_CFHiddenWeapon.call(this);
        this._hiddenWeaponCooldown = 0;
    };

    const _Game_Player_update_CFHiddenWeapon = Game_Player.prototype.update;
    Game_Player.prototype.update = function(sceneActive) {
        _Game_Player_update_CFHiddenWeapon.call(this, sceneActive);
        if (this._hiddenWeaponCooldown > 0) {
            this._hiddenWeaponCooldown--;
        }
        this.updateHiddenWeaponInput();
    };

    Game_Player.prototype.updateHiddenWeaponInput = function() {
        if (!(SceneManager._scene instanceof Scene_Map)) return;
        if ($gameMessage && $gameMessage.isBusy()) return;
        if (SceneManager.isSceneChanging()) return;

        const actor = getLeader();

        if (Input.isTriggered(HIDDEN_INPUT_SYMBOL)) {
            const weapon = findEquippedHiddenWeapon(actor);

            if (!weapon) {
                
                playSe(EMPTY_SE);
                return;
            }

            if (!canUseHiddenWeapon(actor, weapon)) {
                playSe(EMPTY_SE);
                return;
            }

            if (this._hiddenWeaponCooldown > 0) {
                return;
            }

            this.fireHiddenWeapon(actor, weapon);
        }
    };

Game_Player.prototype.fireHiddenWeapon = function(actor, weapon) {
    const count = hiddenWeaponCount(weapon);
    if (count <= 0) {
        playSe(EMPTY_SE);
        return false;
    }

    consumeHiddenWeapon(actor, weapon, 1);
    this._hiddenWeaponCooldown = weaponCooldown(weapon);

    const projectile = new Game_HiddenWeaponProjectile(actor, weapon);
    $gameMap.addHiddenWeaponProjectile(projectile);

    playSe(FIRE_SE);
    return true;
};

function Game_HiddenWeaponProjectile() {
    this.initialize(...arguments);
}

    Game_HiddenWeaponProjectile.prototype.initialize = function(actor, weapon) {
        this._actor = actor;
        this._weapon = weapon;
        this._index = weaponIndex(weapon);
        this._speed = weaponSpeed(weapon);
        this._range = weaponRange(weapon);
        this._distance = 0;
        this._dead = false;
        this._rotation = 0;
        this._hitTargets = [];

        const vec = leaderDirectionVector();
        this._dx = vec.dx;
        this._dy = vec.dy;

        this._realX = $gamePlayer._realX + 0.5;
        this._realY = $gamePlayer._realY + 0.5;
        this._x = this._realX;
        this._y = this._realY;
        this._step = this._speed / 24;
    };

    Game_HiddenWeaponProjectile.prototype.update = function() {
        if (this._dead) return;

        this._realX += this._dx * this._step;
        this._realY += this._dy * this._step;
        this._x = this._realX;
        this._y = this._realY;
        this._distance += this._step;
        this._rotation += 0.35;

        this.checkHitEnemies();

        if (this._distance >= this._range) {
            this._dead = true;
        }
    };

    Game_HiddenWeaponProjectile.prototype.checkHitEnemies = function() {
        const events = $gameMap.events();
        for (let i = 0; i < events.length; i++) {
            const ev = events[i];
            if (!this.canHitEvent(ev)) continue;

            const ex = ev._realX + 0.5;
            const ey = ev._realY + 0.5;
            const dx = this._realX - ex;
            const dy = this._realY - ey;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist <= 0.45) {
                this.onHitEnemy(ev);
                this._dead = true;
                return;
            }
        }
    };

    Game_HiddenWeaponProjectile.prototype.canHitEvent = function(ev) {
        if (!ev || ev._erased) return false;
        if (!ev._enemyEntity) return false;
        if (ev._hp == null || ev._hp <= 0) return false;
        if (this._hitTargets.includes(ev.eventId())) return false;
        return true;
    };

    Game_HiddenWeaponProjectile.prototype.onHitEnemy = function(enemyEvent) {
        this._hitTargets.push(enemyEvent.eventId());
        const result = calcHiddenWeaponDamage(this._actor, enemyEvent, this._weapon);
        applyHiddenWeaponResult(this._actor, enemyEvent, this._weapon, result);
    };

    Game_HiddenWeaponProjectile.prototype.screenX = function() {
        return Math.round($gameMap.adjustX(this._x) * $gameMap.tileWidth());
    };

    Game_HiddenWeaponProjectile.prototype.screenY = function() {
        return Math.round($gameMap.adjustY(this._y) * $gameMap.tileHeight());
    };

    Game_HiddenWeaponProjectile.prototype.rotation = function() {
        return this._rotation;
    };

    Game_HiddenWeaponProjectile.prototype.index = function() {
        return this._index;
    };

    Game_HiddenWeaponProjectile.prototype.isDead = function() {
        return this._dead;
    };

    const _Game_Map_initialize_CFHiddenWeapon = Game_Map.prototype.initialize;
    Game_Map.prototype.initialize = function() {
        _Game_Map_initialize_CFHiddenWeapon.call(this);
        this._hiddenWeaponProjectiles = [];
    };

    const _Game_Map_setup_CFHiddenWeapon = Game_Map.prototype.setup;
    Game_Map.prototype.setup = function(mapId) {
        _Game_Map_setup_CFHiddenWeapon.call(this, mapId);
        this._hiddenWeaponProjectiles = [];
    };

    Game_Map.prototype.hiddenWeaponProjectiles = function() {
        if (!this._hiddenWeaponProjectiles) {
            this._hiddenWeaponProjectiles = [];
        }
        return this._hiddenWeaponProjectiles;
    };

    Game_Map.prototype.addHiddenWeaponProjectile = function(projectile) {
        this.hiddenWeaponProjectiles().push(projectile);
    };

    const _Game_Map_update_CFHiddenWeapon = Game_Map.prototype.update;
    Game_Map.prototype.update = function(sceneActive) {
        _Game_Map_update_CFHiddenWeapon.call(this, sceneActive);
        this.updateHiddenWeaponProjectiles();
    };

    Game_Map.prototype.updateHiddenWeaponProjectiles = function() {
        const list = this.hiddenWeaponProjectiles();
        for (let i = list.length - 1; i >= 0; i--) {
            const p = list[i];
            if (!p) continue;
            p.update();
            if (p.isDead()) {
                list.splice(i, 1);
            }
        }
    };

    function Sprite_HiddenWeaponProjectile() {
        this.initialize(...arguments);
    }

    Sprite_HiddenWeaponProjectile.prototype = Object.create(Sprite.prototype);
    Sprite_HiddenWeaponProjectile.prototype.constructor = Sprite_HiddenWeaponProjectile;

    Sprite_HiddenWeaponProjectile.prototype.initialize = function(projectile) {
        Sprite.prototype.initialize.call(this);
        this._projectile = projectile;
        this.anchor.x = 0.5;
        this.anchor.y = 0.5;
        this.z = 8;
        this.loadBitmap();
        this.update();
    };

    Sprite_HiddenWeaponProjectile.prototype.loadBitmap = function() {
        try {
            const bitmap = ImageManager.loadCharacter("$Hidden_Weapon");
            this.bitmap = bitmap;
            bitmap.addLoadListener(() => {
                if (!bitmap || !bitmap.width || !bitmap.height) return;
                this.refreshFrame();
            });
        } catch (e) {
            console.error("[HiddenWeapon] 投射物图片加载失败:", e);
        }
    };

    Sprite_HiddenWeaponProjectile.prototype.refreshFrame = function() {
        if (!this.bitmap) return;

        const index = this._projectile.index();
        const charW = this.bitmap.width / 12;
        const charH = this.bitmap.height / 8;

        const blockX = (index % 4) * 3 * charW;
        const blockY = Math.floor(index / 4) * 4 * charH;

        const sx = blockX + charW;
        const sy = blockY + charH;

        this.setFrame(sx, sy, charW, charH);
    };

    Sprite_HiddenWeaponProjectile.prototype.update = function() {
        Sprite.prototype.update.call(this);
        if (!this._projectile) return;
        this.x = this._projectile.screenX();
        this.y = this._projectile.screenY() - 18;
        this.rotation = this._projectile.rotation();
        this.visible = !this._projectile.isDead();
    };

    const _Spriteset_Map_createUpperLayer_CFHiddenWeapon = Spriteset_Map.prototype.createUpperLayer;
    Spriteset_Map.prototype.createUpperLayer = function() {
        _Spriteset_Map_createUpperLayer_CFHiddenWeapon.call(this);
        this.createHiddenWeaponLayer();
    };

    Spriteset_Map.prototype.createHiddenWeaponLayer = function() {
        this._hiddenWeaponContainer = new Sprite();
        this.addChild(this._hiddenWeaponContainer);
        this._hiddenWeaponSprites = [];
    };

    const _Spriteset_Map_update_CFHiddenWeapon = Spriteset_Map.prototype.update;
    Spriteset_Map.prototype.update = function() {
        _Spriteset_Map_update_CFHiddenWeapon.call(this);
        this.updateHiddenWeaponSprites();
    };

    Spriteset_Map.prototype.updateHiddenWeaponSprites = function() {
        if (!this._hiddenWeaponContainer) return;

        const projectiles = $gameMap.hiddenWeaponProjectiles();

        for (let i = this._hiddenWeaponSprites.length - 1; i >= 0; i--) {
            const sprite = this._hiddenWeaponSprites[i];
            if (!sprite || !sprite._projectile || sprite._projectile.isDead()) {
                if (sprite) this._hiddenWeaponContainer.removeChild(sprite);
                this._hiddenWeaponSprites.splice(i, 1);
            }
        }

        for (let i = 0; i < projectiles.length; i++) {
            const p = projectiles[i];
            if (!p) continue;

            const exists = this._hiddenWeaponSprites.some(s => s._projectile === p);
            if (!exists) {
                const sprite = new Sprite_HiddenWeaponProjectile(p);
                this._hiddenWeaponContainer.addChild(sprite);
                this._hiddenWeaponSprites.push(sprite);
            }
        }
    };

    function Window_HiddenWeaponUI() {
        this.initialize(...arguments);
    }

    Window_HiddenWeaponUI.prototype = Object.create(Window_Base.prototype);
    Window_HiddenWeaponUI.prototype.constructor = Window_HiddenWeaponUI;

    Window_HiddenWeaponUI.prototype.initialize = function() {
        const rect = new Rectangle(WINDOW_X, WINDOW_Y, WINDOW_WIDTH, WINDOW_HEIGHT);
        Window_Base.prototype.initialize.call(this, rect);
        this.opacity = 0;
        this.contentsOpacity = 255;
        this._lastRefreshKey = "";
        this.refresh();
    };

    Window_HiddenWeaponUI.prototype.update = function() {
        Window_Base.prototype.update.call(this);
        this.updateVisibility();
        this.updateRefresh();
    };

    Window_HiddenWeaponUI.prototype.currentWeapon = function() {
        const actor = getLeader();
        return findEquippedHiddenWeapon(actor);
    };

    Window_HiddenWeaponUI.prototype.updateVisibility = function() {
        const weapon = this.currentWeapon();

        if (!(SceneManager._scene instanceof Scene_Map)) {
            this.visible = false;
            return;
        }

        if (!weapon) {
            this.visible = false;
            return;
        }

        const count = hiddenWeaponCount(weapon);
        this.visible = count > 0 || EMPTY_SLOT_VISIBLE;
    };

    Window_HiddenWeaponUI.prototype.makeRefreshKey = function() {
        const weapon = this.currentWeapon();
        if (!weapon) return "none";

        return JSON.stringify({
            weaponId: weapon.id,
            count: hiddenWeaponCount(weapon),
            index: weaponIndex(weapon),
            cd: $gamePlayer ? ($gamePlayer._hiddenWeaponCooldown || 0) : 0
        });
    };

    Window_HiddenWeaponUI.prototype.updateRefresh = function() {
        const key = this.makeRefreshKey();
        if (this._lastRefreshKey !== key) {
            this._lastRefreshKey = key;
            this.refresh();
        }
    };

    Window_HiddenWeaponUI.prototype.refresh = function() {
        this.contents.clear();

        const weapon = this.currentWeapon();
        if (!weapon) return;

        const count = hiddenWeaponCount(weapon);

        const slotX = Math.floor((this.contentsWidth() - SLOT_SIZE) / 2);
        const slotY = Math.floor((this.contentsHeight() - SLOT_SIZE) / 2);

        this.drawSlotBackground(slotX, slotY, SLOT_SIZE, SLOT_SIZE, SLOT_RADIUS);
if (count > 0) {
    // 先画图标
    this.drawWeaponIconFromCharset(
        weaponIndex(weapon),
        slotX,
        slotY,
        SLOT_SIZE,
        SLOT_SIZE
    );

    // 再画数量（叠加）
    this.contents.fontSize = 16;
    this.changeTextColor("#ffffff");
    this.contents.outlineColor = "rgba(0,0,0,1)";
    this.contents.outlineWidth = 3;

    this.drawText(
        String(count),
        slotX,           // 跟图标对齐
        slotY + 7,      // 往下偏一点
        SLOT_SIZE - 2,
        "right"
    );
} else if (!EMPTY_SLOT_VISIBLE) {
    return;
}

        this.drawSlotFrame(slotX, slotY, SLOT_SIZE, SLOT_SIZE, SLOT_RADIUS);

        this.contents.fontSize = 16;
        this.changeTextColor("#ffffff");
        this.contents.outlineColor = "rgba(0,0,0,1)";
        this.contents.outlineWidth = 3;
        this.contents.fontSize = 16;
        this.changeTextColor("#ffffff");
        this.contents.outlineColor = "rgba(0,0,0,1)";
        this.contents.outlineWidth = 3;
        this.drawText(HIDDEN_KEY_NAME, 1, 24, 18, "left");

        const cd = $gamePlayer ? Math.max(0, $gamePlayer._hiddenWeaponCooldown || 0) : 0;
        if (cd > 0) {
this.fillRoundRect(slotX, slotY, SLOT_SIZE, SLOT_SIZE, SLOT_RADIUS, "rgba(0,0,0,0.50)");
this.contents.fontSize = 16;
this.changeTextColor("#ffffff");
this.drawText(String(cd), slotX, slotY + 6, SLOT_SIZE, "center");
        }

        this.resetFontSettings();
    };

    Window_HiddenWeaponUI.prototype.drawWeaponIconFromCharset = function(index, x, y, dw, dh) {
        try {
            const bitmap = ImageManager.loadCharacter("$Hidden_Weapon");
            bitmap.addLoadListener(() => {
                if (!bitmap || !bitmap.width || !bitmap.height) return;

                const charW = bitmap.width / 12;
                const charH = bitmap.height / 8;
                const blockX = (index % 4) * 3 * charW;
                const blockY = Math.floor(index / 4) * 4 * charH;
                const sx = blockX + charW;
                const sy = blockY + charH;
                this.contents.blt(bitmap, sx, sy, charW, charH, x, y, dw, dh);
            });
        } catch (e) {
            console.error("[HiddenWeapon] UI图标加载失败:", e);
        }
    };

    Window_HiddenWeaponUI.prototype.fillRoundRect = function(x, y, width, height, radius, color) {
        const ctx = this.contents.context || this.contents._context;
        if (!ctx) return;

        ctx.save();
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.moveTo(x + radius, y);
        ctx.lineTo(x + width - radius, y);
        ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
        ctx.lineTo(x + width, y + height - radius);
        ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
        ctx.lineTo(x + radius, y + height);
        ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
        ctx.lineTo(x, y + radius);
        ctx.quadraticCurveTo(x, y, x + radius, y);
        ctx.closePath();
        ctx.fill();
        ctx.restore();

        if (this.contents.baseTexture) {
            this.contents.baseTexture.update();
        } else if (this.contents._baseTexture) {
            this.contents._baseTexture.update();
        } else if (this.contents._setDirty) {
            this.contents._setDirty();
        }
    };

    Window_HiddenWeaponUI.prototype.strokeRoundRect = function(x, y, width, height, radius, color, lineWidth) {
        const ctx = this.contents.context || this.contents._context;
        if (!ctx) return;

        ctx.save();
        ctx.strokeStyle = color;
        ctx.lineWidth = lineWidth || 1;
        ctx.beginPath();
        ctx.moveTo(x + radius, y);
        ctx.lineTo(x + width - radius, y);
        ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
        ctx.lineTo(x + width, y + height - radius);
        ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
        ctx.lineTo(x + radius, y + height);
        ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
        ctx.lineTo(x, y + radius);
        ctx.quadraticCurveTo(x, y, x + radius, y);
        ctx.closePath();
        ctx.stroke();
        ctx.restore();

        if (this.contents.baseTexture) {
            this.contents.baseTexture.update();
        } else if (this.contents._baseTexture) {
            this.contents._baseTexture.update();
        } else if (this.contents._setDirty) {
            this.contents._setDirty();
        }
    };

    Window_HiddenWeaponUI.prototype.drawSlotBackground = function(x, y, width, height, radius) {
        this.fillRoundRect(x, y, width, height, radius, "rgba(0, 0, 0, 0.5)");
    };

    Window_HiddenWeaponUI.prototype.drawSlotFrame = function(x, y, width, height, radius) {
        this.strokeRoundRect(x, y, width, height, radius, "rgba(255,255,255,0.15)", 1);
    };

    const _Scene_Map_createAllWindows_CFHiddenWeapon = Scene_Map.prototype.createAllWindows;
    Scene_Map.prototype.createAllWindows = function() {
        _Scene_Map_createAllWindows_CFHiddenWeapon.call(this);
        this.createHiddenWeaponWindow();
    };

    Scene_Map.prototype.createHiddenWeaponWindow = function() {
        if (this._hiddenWeaponWindow) {
            this.removeChild(this._hiddenWeaponWindow);
            this._hiddenWeaponWindow = null;
        }

        this._hiddenWeaponWindow = new Window_HiddenWeaponUI();
        this.addWindow(this._hiddenWeaponWindow);
    };

})();
