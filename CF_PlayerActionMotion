    Sprite_Character.prototype.updateCFRemoteWeaponSprite = function() {
        if (this._character !== $gamePlayer) return;
        if (!this.parent) return;

        if (!this._cfRemoteWeaponSprite) {
            this._cfRemoteWeaponSprite = new Sprite_CFRemoteWeapon($gamePlayer);
            this._cfRemoteWeaponSprite._cfOwnerSprite = this;
        }

        var imageSprite = this._cfRemoteWeaponSprite;
        imageSprite._cfOwnerSprite = this;

        var parent = this.parent;
        var frame = $gamePlayer.cfCurrentRemoteWeaponFrame ? $gamePlayer.cfCurrentRemoteWeaponFrame() : null;
        var behind = cfPamRemoteImageBehindCharacter(frame);

        if (imageSprite.parent) {
            imageSprite.parent.removeChild(imageSprite);
        }

        var playerIndex = parent.getChildIndex(this);

        if (behind) {
            parent.addChildAt(imageSprite, playerIndex);
        } else {
            parent.addChildAt(imageSprite, Math.min(playerIndex + 1, parent.children.length));
        }
    };

