(function() {

    //==================================================
    // 1. 按键绑定
    //==================================================
var MAP_SKILL_SLOT_COUNT = 6;
Input.keyMapper[81] = "skillQ";
Input.keyMapper[87] = "skillW";
Input.keyMapper[69] = "skillE";
Input.keyMapper[82] = "skillR";
Input.keyMapper[68] = "skillD";
Input.keyMapper[70] = "skillF";

    //==================================================
    // 2. 配置
    //==================================================

var SKILL_SLOT_COLORS = [
    "#4fc3f7",
    "#81c784",
    "#ffb74d",
    "#e57373",
    "#ba68c8",
    "#ffd54f"
];

var SWORD_WTYPE_ID = 1;
var BOW_WTYPE_ID   = 2;

Game_Actor.prototype.mapSkillWeaponTypeId = function() {
    var weapons = this.weapons();
    if (!weapons || weapons.length === 0 || !weapons[0]) {
        return 0;
    }
    return weapons[0].wtypeId || 0;
};

Game_Actor.prototype.initMapSkillSlotsIfNeeded = function() {
    if (!this._mapSkillSlotsByWeapon) {
        this._mapSkillSlotsByWeapon = {};
    }

if (!Array.isArray(this._mapSkillSlotsByWeapon[SWORD_WTYPE_ID])) {
    this._mapSkillSlotsByWeapon[SWORD_WTYPE_ID] = Array(MAP_SKILL_SLOT_COUNT).fill(0);
}

if (!Array.isArray(this._mapSkillSlotsByWeapon[BOW_WTYPE_ID])) {
    this._mapSkillSlotsByWeapon[BOW_WTYPE_ID] = Array(MAP_SKILL_SLOT_COUNT).fill(0);
}
};

Game_Actor.prototype.ensureMapSkillSlots = function(wtypeId) {
    this.initMapSkillSlotsIfNeeded();

    if (!this._mapSkillSlotsByWeapon[wtypeId]) {
        this._mapSkillSlotsByWeapon[wtypeId] = Array(MAP_SKILL_SLOT_COUNT).fill(0);
    }

    while (this._mapSkillSlotsByWeapon[wtypeId].length < MAP_SKILL_SLOT_COUNT) {
        this._mapSkillSlotsByWeapon[wtypeId].push(0);
    }

    return this._mapSkillSlotsByWeapon[wtypeId];
};

Game_Actor.prototype.mapSkillIds = function() {
    var wtypeId = this.mapSkillWeaponTypeId();
    if (wtypeId <= 0) {
        return Array(MAP_SKILL_SLOT_COUNT).fill(0);
    }

    return this.ensureMapSkillSlots(wtypeId).slice(0, MAP_SKILL_SLOT_COUNT);
};

Game_Actor.prototype.mapSkillIdAtSlot = function(slotIndex) {
    var skillIds = this.mapSkillIds();
    return Number(skillIds[slotIndex] || 0);
};

Game_Actor.prototype.setMapSkillAtSlot = function(slotIndex, skillId) {
    var wtypeId = this.mapSkillWeaponTypeId();
    if (wtypeId <= 0) return false;
    if (slotIndex < 0 || slotIndex >= MAP_SKILL_SLOT_COUNT) return false;

    var slots = this.ensureMapSkillSlots(wtypeId);
    slots[slotIndex] = Number(skillId || 0);
    return true;
};

Game_Actor.prototype.clearMapSkillAtSlot = function(slotIndex) {
    return this.setMapSkillAtSlot(slotIndex, 0);
};


    //==================================================
    // 4. 玩家更新：监听 QWER
    //==================================================
var _Game_Player_initialize = Game_Player.prototype.initialize;
Game_Player.prototype.initialize = function() {
    _Game_Player_initialize.call(this);
    this._skillCooldowns = {};
};

var _Game_Player_update = Game_Player.prototype.update;
Game_Player.prototype.update = function(sceneActive) {
    _Game_Player_update.call(this, sceneActive);
    this.updateSkillCooldowns();
    this.updateSkillInput();
};

    //技能冷却
    Game_Player.prototype.skillCooldownTime = function(skill) {
        if (!skill) return 0;
        const match = skill.note.match(/<cooldown:(\d+)>/i);
        return match ? Number(match[1]) : 0;
    };

Game_Player.prototype.updateSkillCooldowns = function() {
    if (!this._skillCooldowns) this._skillCooldowns = {};

    for (var skillId in this._skillCooldowns) {
        if (!this._skillCooldowns.hasOwnProperty(skillId)) continue;

        if (this._skillCooldowns[skillId] > 0) {
            this._skillCooldowns[skillId]--;

            if (this._skillCooldowns[skillId] === 0) {
                this.playSkillReadySe(Number(skillId));
            }
        }

        if (this._skillCooldowns[skillId] <= 0) {
            delete this._skillCooldowns[skillId];
        }
    }
};

Game_Player.prototype.canUseMapSkillByInput = function() {
    if ($gameMessage.isBusy()) return false;
    if ($gameMap.isEventRunning()) return false;
    return true;
};

Game_Player.prototype.updateSkillInput = function() {
    if (!this.canUseMapSkillByInput()) return;

    if (Input.isTriggered("skillQ")) {
        this.useMapSkillBySlot(0);
    } else if (Input.isTriggered("skillW")) {
        this.useMapSkillBySlot(1);
    } else if (Input.isTriggered("skillE")) {
        this.useMapSkillBySlot(2);
    } else if (Input.isTriggered("skillR")) {
        this.useMapSkillBySlot(3);
    } else if (Input.isTriggered("skillD")) {
        this.useMapSkillBySlot(4);
    } else if (Input.isTriggered("skillF")) {
        this.useMapSkillBySlot(5);
    }
};

    //==================================================
    // 5. 基础对象
    //==================================================
    Game_Player.prototype.playerBattler = function() {
        return $gameParty.leader();
    };

    //==================================================
    // 6. 技能距离
    //==================================================
    Game_Player.prototype.skillRange = function(skill) {
        if (!skill) return 1;

        var note = skill.note || "";
        var match = note.match(/<range:(\d+)>/i);

        if (match) {
            return Math.max(1, Number(match[1]));
        }

        return 1;
    };

Game_Player.prototype.skillCooldownLeft = function(skillId) {
    if (!this._skillCooldowns) this._skillCooldowns = {};
    return this._skillCooldowns[skillId] || 0;
};

Game_Player.prototype.isSkillOnCooldown = function(skillId) {
    return this.skillCooldownLeft(skillId) > 0;
};

Game_Player.prototype.startSkillCooldown = function(skillId, skill) {
    if (!skillId || !skill) return;

    if (!this._skillCooldowns) this._skillCooldowns = {};

    var cd = this.skillCooldownTime(skill);
    if (cd > 0) {
        this._skillCooldowns[skillId] = cd;
    }
};

    //==================================================
    // 7. 技能槽 -> 技能ID
    //==================================================
Game_Player.prototype.mapSkillIdBySlot = function(slotIndex) {
    var actor = this.playerBattler();
    if (!actor) return 0;

    var skillIds = actor.mapSkillIds ? actor.mapSkillIds() : Array(MAP_SKILL_SLOT_COUNT).fill(0);
    var skillId = Number(skillIds[slotIndex] || 0);
    if (skillId <= 0) return 0;

    if (!actor.isLearnedSkill || !actor.isLearnedSkill(skillId)) {
        return 0;
    }

    return skillId;
};

Game_Player.prototype.useMapSkillBySlot = function(slotIndex) {
    var actor = this.playerBattler();
    if (!actor) return false;

    var wtypeId = actor.mapSkillWeaponTypeId ? actor.mapSkillWeaponTypeId() : 0;
    var skillId = this.mapSkillIdBySlot(slotIndex);

    // 没装备武器：不允许打开技能选择窗口
    if (wtypeId <= 0) {
        AudioManager.playSe({
            name: "Cancel2",
            volume: 30,
            pitch: 80,
            pan: 0
        });
        return false;
    }

    // 空槽：打开技能选择窗口
    if (skillId <= 0) {
        var scene = SceneManager._scene;
        if (scene && scene.openPlayerSkillSelectionWindow) {
            scene.openPlayerSkillSelectionWindow(slotIndex);
            return true;
        }
        return false;
    }

    return this.useMapSkill(skillId, slotIndex);
};

    //==================================================
    // 8. 使用技能槽技能
    //==================================================
Game_Player.prototype.useMapSkill = function(skillId, slotIndex) {
    var actor = this.playerBattler();
    if (!actor) return false;

var skill = $dataSkills[skillId];
if (!skill) return false;

var needRejectSe = this.shouldPlaySkillRejectSe(skill);

// CF: Block repeated casting while this skill is on cooldown.
// This also applies to normal attack because CF_Attack calls useMapSkill(skillId, -1).
if (this.isSkillOnCooldown && this.isSkillOnCooldown(skillId)) {
    if (needRejectSe) {
        AudioManager.playSe({
            name: "Cancel2",
            volume: 30,
            pitch: 80,
            pan: 0
        });
    }
    return false;
}

if (!actor.canPaySkillCost(skill)) {
    if (needRejectSe) {
        AudioManager.playSe({
            name: "Cancel2",
            volume: 30,
            pitch: 80,
            pan: 0
        });
    }
    return false;
}

    if (this._motionPlaying) {
        return false;
    }

    if (this._pendingAttackObjects && this._pendingAttackObjects.length > 0) {
        return false;
    }

    var type = this.skillAttackObjectType ? this.skillAttackObjectType(skill) : "";
    if (!type) return false;

    if (!actor.canPaySkillCost(skill)) {
        if (needRejectSe) {
            AudioManager.playSe({
                name: "Cancel2",
                volume: 30,
                pitch: 80,
                pan: 0
            });
        }
        return false;
    }

    actor.paySkillCost(skill);

    if (this.queueAttackObject) {
        this.queueAttackObject(skill, type);
    }

if (slotIndex >= 0) {
    this.showSkillNamePopup(skill, slotIndex);
}

    this.startSkillCooldown(skillId, skill);
    return true;
};

Game_Player.prototype.playSkillReadySe = function(skillId) {
    var skill = $dataSkills[skillId];
    if (!skill) return;

    if (!this.shouldPlaySkillReadySe(skill)) {
        return;
    }

    AudioManager.playSe({
        name: "Saint5",
        volume: 20,
        pitch: 60,
        pan: 0
    });
};

//==================================================
// 9. 技能名提示
//==================================================

Game_Player.prototype.showSkillNamePopup = function(skill, slotIndex) {
    if (!skill || !SceneManager._scene) return;

    var scene = SceneManager._scene;
    if (!(scene instanceof Scene_Map)) return;

    if (!scene._mapSkillNameSprite) {
        scene.createMapSkillNameSprite();
    }

    var color = SKILL_SLOT_COLORS[slotIndex] || "#ffffff";

    if (scene._mapSkillNameSprite) {
        scene._mapSkillNameSprite.showSkillName(skill.name, color);
    }
};

//==================================================
// 10. 地图场景：创建技能名精灵
//==================================================
Scene_Map.prototype.createMapSkillNameSprite = function() {
    this._mapSkillNameSprite = new Sprite_MapSkillName();
    this.addChild(this._mapSkillNameSprite);
};

//==================================================
// 11. 技能名精灵
//==================================================
function Sprite_MapSkillName() {
    this.initialize.apply(this, arguments);
}

Sprite_MapSkillName.prototype = Object.create(Sprite.prototype);
Sprite_MapSkillName.prototype.constructor = Sprite_MapSkillName;

Sprite_MapSkillName.prototype.initialize = function() {
    Sprite.prototype.initialize.call(this);
    this.bitmap = new Bitmap(240, 48);
    this.anchor.x = 0.5;
    this.anchor.y = 1;

    this.opacity = 0;
    this.visible = false;

    this._duration = 0;
    this._time = 0;

    this._baseX = 0;
    this._baseY = 0;
};

Sprite_MapSkillName.prototype.showSkillName = function(text, color) {
    this.bitmap.clear();
    this.bitmap.fontSize = 22;
    this.bitmap.outlineColor = "rgba(0, 0, 0, 1)";
    this.bitmap.outlineWidth = 4;
    this.bitmap.textColor = color || "#ffffff";
    this.bitmap.drawText(text, 0, 0, this.bitmap.width, 36, "center");

    this.opacity = 255;
    this.visible = true;

    this._duration = 60;
    this._time = 0;

    this.updateBasePosition();
};

Sprite_MapSkillName.prototype.update = function() {
    Sprite.prototype.update.call(this);

    if (!this.visible) return;

    this._time++;

    this.updateBasePosition();

    var rise = this._time * 0.8;
    var swing = Math.sin(this._time * 0.25) * 12;

    this.x = this._baseX + swing;
    this.y = this._baseY - rise;

    if (this._time > 35) {
        this.opacity -= 8;
    }

    if (this._time >= this._duration) {
        this.opacity = 0;
        this.visible = false;
        this.bitmap.clear();
    }
};

Sprite_MapSkillName.prototype.updateBasePosition = function() {
    if (!$gamePlayer) return;

    var th = $gameMap.tileHeight();

    this._baseX = $gamePlayer.screenX();
    this._baseY = $gamePlayer.screenY() - th;
};

function skillHasMetaTag(skill, tagName) {
    if (!skill) return false;
    var meta = skill.meta || {};
    return !!meta[tagName];
}

Game_Player.prototype.shouldPlaySkillRejectSe = function(skill) {
    if (!skill) return false;
    if (skillHasMetaTag(skill, "normalAttackSkill")) return false;
