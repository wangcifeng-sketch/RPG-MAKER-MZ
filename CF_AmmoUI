/*:
 * @target MZ
 * @plugindesc 弓箭UI窗口（只在装备弓时显示当前箭图标和数量）
 * @author ChatGPT
 *
 * @param WindowX
 * @text UI X坐标
 * @type number
 * @default 795
 *
 * @param WindowY
 * @text UI Y坐标
 * @type number
 * @default 630
 *
 * @param WindowSize
 * @text 窗口尺寸
 * @type number
 * @default 56
 *
 * @help
 * =========================================================
 * ■ 说明
 * =========================================================
 * 本插件用于显示“当前箭”的图标和数量。
 *
 * 只在以下条件成立时显示：
 * ● 当前装备的是弓
 * ● 弓配置了 <ammoWeaponIds:...>
 *
 * 依赖：
 * ● CF_BowAmmoSystem.js
 *
 * 推荐放在：
 * ● CF_BowAmmoSystem.js 后面
 * =========================================================
 */

(() => {
    "use strict";

    const parameters = PluginManager.parameters("CF_AmmoUI");

    const WINDOW_X = Number(parameters["WindowX"] || 795);
    const WINDOW_Y = Number(parameters["WindowY"] || 630);
    const WINDOW_SIZE = Number(parameters["WindowSize"] || 56);

    const CORNER_RADIUS = 8;
    const BORDER_COLOR = "rgba(255,255,255,0.22)";
    const BG_COLOR = "rgba(0,0,0,0.50)";
    const BORDER_WIDTH = 1;

    function getLeader() {
        return $gameParty ? $gameParty.leader() : null;
    }

    function currentWeapon(actor) {
        if (!actor || !actor.weapons) return null;
        const weapons = actor.weapons();
        return (weapons && weapons.length > 0) ? weapons[0] : null;
    }

    function isBowWeapon(weapon) {
        if (!weapon) return false;
        if (weapon.wtypeId === 2) return true;
        return /<ammoWeaponIds:/i.test(weapon.note || "");
    }

    function hasAmmoConfig(actor) {
        return !!(actor &&
            typeof actor.bowAmmoWeaponIds === "function" &&
            actor.bowAmmoWeaponIds().length > 0);
    }

    function currentAmmo(actor) {
        if (!actor || typeof actor.currentAmmoWeapon !== "function") return null;
        return actor.currentAmmoWeapon();
    }

    function ammoCount(ammo) {
        if (!ammo || !$gameParty) return 0;
        return $gameParty.numItems(ammo);
    }

    function makeAmmoRefreshKey() {
        const actor = getLeader();
        if (!actor) return "no_actor";

        const weapon = currentWeapon(actor);
        const ammo = currentAmmo(actor);

        return JSON.stringify({
            weaponId: weapon ? weapon.id : 0,
            isBow: !!isBowWeapon(weapon),
            ammoId: ammo ? ammo.id : 0,
            count: ammo ? ammoCount(ammo) : 0
        });
    }

function Window_PlayerAmmo() {
    this.initialize(...arguments);
}

Window_PlayerAmmo.prototype = Object.create(Window_Base.prototype);
Window_PlayerAmmo.prototype.constructor = Window_PlayerAmmo;

Window_PlayerAmmo.prototype.initialize = function() {
    const rect = new Rectangle(WINDOW_X, WINDOW_Y, WINDOW_SIZE, WINDOW_SIZE);
    Window_Base.prototype.initialize.call(this, rect);
    this.opacity = 0;
    this.contentsOpacity = 255;
    this._lastRefreshKey = "";
    this.refresh();
};

Window_PlayerAmmo.prototype.update = function() {
    Window_Base.prototype.update.call(this);
    this.updateRefresh();
    this.updateVisibility();
};

    Window_PlayerAmmo.prototype.updateVisibility = function() {
        const actor = getLeader();
        const weapon = currentWeapon(actor);

        const shouldShow =
            SceneManager._scene instanceof Scene_Map &&
            actor &&
            weapon &&
            isBowWeapon(weapon) &&
            hasAmmoConfig(actor);

        this.visible = !!shouldShow;
    };

    Window_PlayerAmmo.prototype.updateRefresh = function() {
        const key = makeAmmoRefreshKey();
        if (this._lastRefreshKey !== key) {
            this._lastRefreshKey = key;
            this.refresh();
        }
    };

    Window_PlayerAmmo.prototype.refresh = function() {
        if (!this.contents) return;
        this.contents.clear();

        const actor = getLeader();
        if (!actor) return;

        const weapon = currentWeapon(actor);
        if (!weapon) return;
        if (!isBowWeapon(weapon)) return;
        if (!hasAmmoConfig(actor)) return;

        const ammo = currentAmmo(actor);

        this.fillRoundRect(0, 0, this.contentsWidth(), this.contentsHeight(), 8, BG_COLOR);
        this.strokeRoundRect(0, 0, this.contentsWidth(), this.contentsHeight(), 8, BORDER_COLOR, 1);

        if (ammo) {
            this.drawAmmoIcon(ammo);
            this.drawAmmoCount(ammoCount(ammo));
        } else {
            this.drawEmptyAmmoCount();
        }
    };

    Window_PlayerAmmo.prototype.drawAmmoIcon = function(ammo) {
        this.drawIcon(ammo.iconIndex || 0, 0, 0);
    };

    Window_PlayerAmmo.prototype.drawAmmoCount = function(count) {
        const text = String(count);
        this.contents.fontSize = 16;
        this.changeTextColor("#ffffff");
        this.contents.outlineColor = "rgba(0,0,0,1)";
        this.contents.outlineWidth = 4;

        this.drawText(text, 14, 7, 32, 18, "right");
        this.resetFontSettings();
    };

    Window_PlayerAmmo.prototype.drawEmptyAmmoCount = function() {
        this.contents.fontSize = 16;
        this.changeTextColor("#ff8080");
        this.contents.outlineColor = "rgba(0,0,0,1)";
        this.contents.outlineWidth = 4;

        this.drawText("0", 14, 7, 32, 18, "right");
        this.resetFontSettings();
    };

    const _Scene_Map_createAllWindows = Scene_Map.prototype.createAllWindows;
    Scene_Map.prototype.createAllWindows = function() {
        _Scene_Map_createAllWindows.call(this);
        this.createPlayerAmmoWindow();
    };

    Scene_Map.prototype.createPlayerAmmoWindow = function() {
        if (this._playerAmmoWindow) {
            this.removeChild(this._playerAmmoWindow);
            this._playerAmmoWindow = null;
        }

        this._playerAmmoWindow = new Window_PlayerAmmo();
        this.addWindow(this._playerAmmoWindow);
    };

Window_PlayerAmmo.prototype.strokeRoundRect = function(x, y, w, h, r, color, lineWidth) {
    const ctx = this.contents.context || this.contents._context;
    if (!ctx) return;

    ctx.save();
    ctx.strokeStyle = color;
    ctx.lineWidth = lineWidth || 1;

    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.lineTo(x + w - r, y);
    ctx.quadraticCurveTo(x + w, y, x + w, y + r);
    ctx.lineTo(x + w, y + h - r);
    ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    ctx.lineTo(x + r, y + h);
    ctx.quadraticCurveTo(x, y + h, x, y + h - r);
    ctx.lineTo(x, y + r);
    ctx.quadraticCurveTo(x, y, x + r, y);
    ctx.closePath();

    ctx.stroke();
    ctx.restore();

    this.contents._baseTexture?.update?.();
};

Window_PlayerAmmo.prototype.fillRoundRect = function(x, y, w, h, r, color) {
    const ctx = this.contents.context || this.contents._context;
    if (!ctx) return;

    ctx.save();
    ctx.fillStyle = color;

    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.lineTo(x + w - r, y);
    ctx.quadraticCurveTo(x + w, y, x + w, y + r);
    ctx.lineTo(x + w, y + h - r);
    ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    ctx.lineTo(x + r, y + h);
    ctx.quadraticCurveTo(x, y + h, x, y + h - r);
    ctx.lineTo(x, y + r);
    ctx.quadraticCurveTo(x, y, x + r, y);
    ctx.closePath();

    ctx.fill();
    ctx.restore();

    this.contents._baseTexture?.update?.();
};

})();
