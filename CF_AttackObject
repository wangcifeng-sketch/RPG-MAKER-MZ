(function() {

var CF_AO_EPS = 0.00001;
var CF_AO_STEP = 0.5;

function cfAoRoundHalf(n) {
    return Math.round(Number(n || 0) * 2) / 2;
}

function cfAoNear(a, b, range) {
    return Math.abs(a - b) <= (range || CF_AO_EPS);
}

function cfAoVectorFromDir(d) {
    switch (d) {
        case 1: return { x: -1, y:  1 };
        case 2: return { x:  0, y:  1 };
        case 3: return { x:  1, y:  1 };
        case 4: return { x: -1, y:  0 };
        case 6: return { x:  1, y:  0 };
        case 7: return { x: -1, y: -1 };
        case 8: return { x:  0, y: -1 };
        case 9: return { x:  1, y: -1 };
        default: return { x: 0, y: 0 };
    }
}

function cfAoDirToHV(d) {
    switch (d) {
        case 1: return [4, 2];
        case 3: return [6, 2];
        case 7: return [4, 8];
        case 9: return [6, 8];
        default: return [0, 0];
    }
}

function cfAoCharX(ch) {
    if (!ch) return 0;
    if (typeof ch.cfHalfX === "function") return cfAoRoundHalf(ch.cfHalfX());
    if (ch._x != null) return cfAoRoundHalf(ch._x);
    return cfAoRoundHalf(ch.x || 0);
}

function cfAoCharY(ch) {
    if (!ch) return 0;
    if (typeof ch.cfHalfY === "function") return cfAoRoundHalf(ch.cfHalfY());
    if (ch._y != null) return cfAoRoundHalf(ch._y);
    return cfAoRoundHalf(ch.y || 0);
}

function cfAoNineGridTouchNoCorner(x1, y1, x2, y2) {
    var dx = Math.abs(cfAoRoundHalf(x1) - cfAoRoundHalf(x2));
    var dy = Math.abs(cfAoRoundHalf(y1) - cfAoRoundHalf(y2));

    if (dx > 1.0 + CF_AO_EPS || dy > 1.0 + CF_AO_EPS) {
        return false;
    }

    // 纯斜角不命中
    if (cfAoNear(dx, 1.0) && cfAoNear(dy, 1.0)) {
        return false;
    }

    return true;
}

function cfAoTargetInForwardSector(ox, oy, tx, ty, dir) {
    ox = cfAoRoundHalf(ox);
    oy = cfAoRoundHalf(oy);
    tx = cfAoRoundHalf(tx);
    ty = cfAoRoundHalf(ty);

    var vec = cfAoVectorFromDir(dir);
    var dx = tx - ox;
    var dy = ty - oy;

    // 用“朝向向量点积 > 0”判断目标是否在前方
    // 这样 1/3/7/9 时也能保留“贴边命中”，
    // 不会被旧版那种“必须同时横纵都严格前进”的条件误杀
    var dot = dx * vec.x + dy * vec.y;
    return dot > CF_AO_EPS;
}

function cfAoAddTileUnique(list, x, y) {
    var key = x + "," + y;
    for (var i = 0; i < list.length; i++) {
        if (list[i].key === key) return;
    }
    list.push({ key: key, x: x, y: y });
}

function cfAoSampleTilesForBody(x, y) {
    var rx = cfAoRoundHalf(x);
    var ry = cfAoRoundHalf(y);

    var left = Math.floor(rx + CF_AO_EPS);
    var right = Math.ceil(rx - CF_AO_EPS);
    var top = Math.floor(ry + CF_AO_EPS);
    var bottom = Math.ceil(ry - CF_AO_EPS);

    var result = [];
    cfAoAddTileUnique(result, left, top);
    cfAoAddTileUnique(result, left, bottom);
    cfAoAddTileUnique(result, right, top);
    cfAoAddTileUnique(result, right, bottom);
    return result;
}

function cfAoBodyPassable(x, y) {
    var tiles = cfAoSampleTilesForBody(x, y);

    for (var i = 0; i < tiles.length; i++) {
        var tx = tiles[i].x;
        var ty = tiles[i].y;

        if (!$gameMap.isValid(tx, ty)) return false;

        var passable =
            $gameMap.isPassable(tx, ty, 2) ||
            $gameMap.isPassable(tx, ty, 4) ||
            $gameMap.isPassable(tx, ty, 6) ||
            $gameMap.isPassable(tx, ty, 8);

        if (!passable) return false;
    }

    return true;
}

    //==================================================
    // 1. 读取技能备注
    //==================================================
    Game_Player.prototype.skillRange = Game_Player.prototype.skillRange || function(skill) {
        if (!skill) return 1;
        var note = skill.note || "";
        var match = note.match(/<range:(\d+)>/i);
        if (match) {
            return Math.max(1, Number(match[1]));
        }
        return 1;
    };

    Game_Player.prototype.skillAttackObjectType = function(skill) {
        if (!skill) return "";
        var note = skill.note || "";
        var match = note.match(/<attackObject:(\w+)>/i);
        return match ? String(match[1]).toLowerCase() : "";
    };

    //==================================================
    // 2. 地图攻击体管理
    //==================================================
var _Game_Map_initialize = Game_Map.prototype.initialize;
Game_Map.prototype.initialize = function() {
    _Game_Map_initialize.call(this);
    this._attackObjects = [];
    this._cfAoEnemyCache = [];
    this._cfAoEnemyCacheDirty = true;
};

var _Game_Map_setup = Game_Map.prototype.setup;
Game_Map.prototype.setup = function(mapId) {
    _Game_Map_setup.call(this, mapId);
    this._attackObjects = [];
    this._cfAoEnemyCache = [];
    this._cfAoEnemyCacheDirty = true;
};

    Game_Map.prototype.attackObjects = function() {
        if (!this._attackObjects) this._attackObjects = [];
        return this._attackObjects;
    };

    Game_Map.prototype.addAttackObject = function(obj) {
        this.attackObjects().push(obj);
    };

Game_Map.prototype.markEnemyTargetCacheDirty = function() {
    this._cfAoEnemyCacheDirty = true;
};

Game_Map.prototype.enemyTargetsForAttackObject = function() {
    if (!this._cfAoEnemyCache) {
        this._cfAoEnemyCache = [];
        this._cfAoEnemyCacheDirty = true;
    }

    if (!this._cfAoEnemyCacheDirty) {
        return this._cfAoEnemyCache;
    }

    var events = this.events();
    var list = [];

    for (var i = 0; i < events.length; i++) {
        var ev = events[i];
        if (!ev || !ev._enemyEntity || ev._hp <= 0) continue;

        list.push(ev);
    }

    this._cfAoEnemyCache = list;
    this._cfAoEnemyCacheDirty = false;
    return list;
};

Game_Map.prototype.removeFinishedAttackObjects = function() {
    var arr = this.attackObjects();
    var write = 0;

    for (var i = 0; i < arr.length; i++) {
        var obj = arr[i];
        if (obj && !obj._finished) {
            arr[write++] = obj;
        } else if (obj) {
            obj._spriteRef = null;
        }
    }

    arr.length = write;
};

    var _Game_Map_update = Game_Map.prototype.update;
    Game_Map.prototype.update = function(sceneActive) {
        _Game_Map_update.call(this, sceneActive);

        var objects = this.attackObjects();
        for (var i = 0; i < objects.length; i++) {
            objects[i].update();
        }

        this.removeFinishedAttackObjects();
    };

    //==================================================
    // 3. 攻击体对象
    //==================================================
    function Game_MapAttackObject() {
        this.initialize.apply(this, arguments);
    }

Game_MapAttackObject.prototype.initialize = function(user, skill, type, startX, startY, startDir) {
    this._user = user;
    this._skill = skill;
    this._skillId = skill ? skill.id : 0;
    this._type = type || "slash";

    this._fromEnemy = (user instanceof Game_Event);
    this._fromPlayer = (user instanceof Game_Player);

    this._direction = (startDir != null
        ? startDir
        : (user.cfInteractionDirection ? user.cfInteractionDirection() : user.direction()));

    this._finished = false;
    this._hitEnemies = [];
    this._hitEnemyMap = Object.create(null);
    this._hitPlayer = false;
    this._frameCount = 0;
    this._pattern = 0;
    this._moveWait = 0;

    this._range = this.readSkillRange(skill);
    this._remainingRange = this._range;

    this._damageEnabled = true;
    this._reachMaxRange = false;
    this._hasHit = false;

    this._startedFromCustomPos = (startX != null || startY != null);
    this._x = (startX != null ? cfAoRoundHalf(startX) : cfAoCharX(user));
    this._y = (startY != null ? cfAoRoundHalf(startY) : cfAoCharY(user));

    this.setupByType();

    if (!this._startedFromCustomPos) {
        this.forwardStart();
    }
};

Game_MapAttackObject.prototype.readSkillRange = function(skill) {
    if (!skill) return 2;

    var note = skill.note || "";
    var match = note.match(/<range:(\d+)>/i);
    var tiles = match ? Math.max(1, Number(match[1])) : 1;

    // 技能配置仍然按“格”，攻击体内部改成“半步数”
    return tiles * 2;
};
    Game_MapAttackObject.prototype.readSkillAttackObjectPic = function(skill) {
        if (!skill) return "";
        var note = skill.note || "";
        var match = note.match(/<attackObjectPic:([^>]+)>/i);
        return match ? String(match[1]).trim() : "";
    };

    Game_MapAttackObject.prototype.minVisualFramesByType = function() {
        if (this._type === "slash") return 6;   // 0,1,2 三帧完整展示
        if (this._type === "punch") return 4;
        if (this._type === "arrow") return 0;   // 箭到头/命中直接消失
        return 4;
    };

    Game_MapAttackObject.prototype.setupByType = function() {
        var customPic = this.readSkillAttackObjectPic(this._skill);
        var note = this._skill ? (this._skill.note || "") : "";

        this._minVisualFrames = this.minVisualFramesByType();

        if (this._type === "arrow") {
            this._speedFrame = 3;
            this._lifetime = Math.max(12, this._range * 10);
            this._pictureName = customPic || "Arrow";
            this._throughAfterHit = /<powerArrow>/i.test(note);

        } else if (this._type === "punch") {
            this._speedFrame = 3;
            this._lifetime = Math.max(12, this._range * 10);
            this._pictureName = customPic || "";
            this._throughAfterHit = /<powerArrow>/i.test(note);

        } else {
            this._speedFrame = 3;
            this._lifetime = Math.max(12, this._range * 10);
            this._pictureName = customPic || "Sword";
            this._throughAfterHit = /<powerArrow>/i.test(note);
        }
    };

Game_MapAttackObject.prototype.forwardStart = function() {
    var vec = cfAoVectorFromDir(this._direction);
    this._x = cfAoRoundHalf(this._x + vec.x * CF_AO_STEP);
    this._y = cfAoRoundHalf(this._y + vec.y * CF_AO_STEP);
};

Game_MapAttackObject.prototype.nextTileXy = function(x, y, d) {
    var vec = cfAoVectorFromDir(d);
    return {
        x: cfAoRoundHalf(x + vec.x * CF_AO_STEP),
        y: cfAoRoundHalf(y + vec.y * CF_AO_STEP)
    };
};

Game_MapAttackObject.prototype.canPassMapTile = function(x, y, d) {
    var next = this.nextTileXy(x, y, d);
    return cfAoBodyPassable(next.x, next.y);
};

Game_MapAttackObject.prototype.onHitWall = function() {
    this._reachMaxRange = true;
    this._damageEnabled = false;
    this._hasHit = true;

    if (this._type === "arrow") {
        this._finished = true;
    }
};

Game_MapAttackObject.prototype.update = function() {
    if (this._finished) return;

    this._frameCount++;
    this.updatePattern();

    var movedThisFrame = false;

    if (!this._reachMaxRange) {
        movedThisFrame = this.updateMove();
    }

    // 只在“出生首帧”或“真正移动到新位置的这一帧”才做碰撞
    if (this._damageEnabled && !this._hasHit) {
        if (this._frameCount === 1 || movedThisFrame) {
            this.updateCollision();
        }
    }

    this._lifetime--;

    if (this._hasHit) {
        if (this._type === "arrow") {
            this._finished = true;
            return;
        }

        if (this._frameCount >= this._minVisualFrames) {
            this._finished = true;
            return;
        }
    }

    if (this._reachMaxRange) {
        if (this._type === "arrow") {
            this._finished = true;
            return;
        }

        if (this._frameCount >= this._minVisualFrames) {
            this._finished = true;
            return;
        }
    }

    if (this._lifetime <= 0) {
        this._finished = true;
    }
};

    Game_MapAttackObject.prototype.updatePattern = function() {
        // 命中或到达最远后，近战固定最后一帧
        if (this._hasHit || this._reachMaxRange) {
            if (this._type !== "arrow") {
                this._pattern = 2;
                return;
            }
        }

        if (this._type === "slash") {
            if (this._frameCount <= 2) {
                this._pattern = 0;
            } else if (this._frameCount <= 4) {
                this._pattern = 1;
            } else {
                this._pattern = 2;
            }
            return;
        }

        if (this._type === "arrow") {
            // 飞行中循环前两帧
            this._pattern = Math.floor(this._frameCount / 4) % 2;
            return;
        }

        if (this._type === "punch") {
            if (this._frameCount <= 2) {
                this._pattern = 0;
            } else if (this._frameCount <= 4) {
                this._pattern = 1;
            } else {
                this._pattern = 2;
            }
            return;
        }

        this._pattern = 0;
    };

Game_MapAttackObject.prototype.updateMove = function() {
    if (this._remainingRange <= 0) {
        this._reachMaxRange = true;
        this._damageEnabled = false;
        return false;
    }

    if (this._speedFrame <= 0) return false;

    this._moveWait++;
    if (this._moveWait < this._speedFrame) return false;
    this._moveWait = 0;

    if (!this.canPassMapTile(this._x, this._y, this._direction)) {
        this.onHitWall();
        return false;
    }

    var next = this.nextTileXy(this._x, this._y, this._direction);
    this._x = next.x;
    this._y = next.y;

    this._remainingRange--;

    if (this._remainingRange <= 0) {
        this._reachMaxRange = true;
        this._damageEnabled = false;
    }

    return true;
};

Game_MapAttackObject.prototype.updateCollision = function() {
    if (!this._damageEnabled) return;
    if (this._hasHit) return;

    var ox = cfAoRoundHalf(this._x);
    var oy = cfAoRoundHalf(this._y);

    if (this._fromPlayer) {
        var targets = $gameMap.enemyTargetsForAttackObject();

        for (var i = 0; i < targets.length; i++) {
            var ev = targets[i];
            var id = ev.eventId();

            if (this._hitEnemyMap[id]) continue;

            var ex = cfAoCharX(ev);
            var ey = cfAoCharY(ev);

            if (Math.abs(ex - ox) > 1.0 + CF_AO_EPS) continue;
            if (Math.abs(ey - oy) > 1.0 + CF_AO_EPS) continue;

            if (!cfAoNineGridTouchNoCorner(ox, oy, ex, ey)) continue;
            if (!cfAoTargetInForwardSector(ox, oy, ex, ey, this._direction)) continue;

            this.applyDamageToEnemy(ev);
            this._hitEnemies.push(id);
            this._hitEnemyMap[id] = true;

            if (!this._throughAfterHit) {
                this._hasHit = true;
                this._damageEnabled = false;
                return;
            }
        }
    }

    if (this._fromEnemy) {
        var px = cfAoCharX($gamePlayer);
        var py = cfAoCharY($gamePlayer);

        if (
            !$gamePlayer.isThrough() &&
            Math.abs(px - ox) <= 1.0 + CF_AO_EPS &&
            Math.abs(py - oy) <= 1.0 + CF_AO_EPS &&
            cfAoNineGridTouchNoCorner(ox, oy, px, py) &&
            cfAoTargetInForwardSector(ox, oy, px, py, this._direction)
        ) {
            if (!this._hitPlayer) {
                this.applyDamageToPlayer();
                this._hitPlayer = true;
            }

            if (!this._throughAfterHit) {
                this._hasHit = true;
                this._damageEnabled = false;
                return;
            }
        }
    }
};

Game_MapAttackObject.prototype.knockbackTarget = function(target, direction) {
    if (!target) return false;

    var fromX = cfAoCharX(target);
    var fromY = cfAoCharY(target);
    var next = this.nextTileXy(fromX, fromY, direction);

    var pass = false;

    if (direction === 2 || direction === 4 || direction === 6 || direction === 8) {
        pass = target.canPass ? target.canPass(fromX, fromY, direction) : cfAoBodyPassable(next.x, next.y);
    } else {
        var hv = cfAoDirToHV(direction);
        pass = target.canPassDiagonally
            ? target.canPassDiagonally(fromX, fromY, hv[0], hv[1])
            : cfAoBodyPassable(next.x, next.y);
    }

    if (!pass) return false;

    if (target.isCollidedWithCharacters && target.isCollidedWithCharacters(next.x, next.y)) {
        return false;
    }

    target.locate(next.x, next.y);
    return true;
};

    Game_MapAttackObject.prototype.applyDamageToEnemy = function(enemyEvent) {
        var actor = this._user.playerBattler ? this._user.playerBattler() : null;
        var skill = this._skill;
        if (!actor || !skill || !enemyEvent || !enemyEvent._enemyEntity) return;

        var enemy = enemyEvent._enemyEntity;

        var successRate = (skill.successRate != null ? skill.successRate : 100) / 100;
        var hitChance = successRate * (actor.hit || 0.95);
        var evaRate = enemy.eva || 0.05;
        var finalHit = Math.max(0.05, hitChance - evaRate);

        if (this._fromPlayer && $gamePlayer.addComboHit) {
            $gamePlayer.addComboHit();
        }

        if (Math.random() > finalHit) {
            if (SoundManager.playMiss) SoundManager.playMiss();
            if (enemyEvent.showDamageText) {
                enemyEvent.showDamageText("MISS", "#aaaaaa");
            }
            return;
        }

        var damage = 0;
        var critical = false;

        if (skill.damage && skill.damage.type > 0) {
            var a = actor;
            var b = enemy;
            var v = $gameVariables._data;

            try {
                damage = Math.floor(eval(skill.damage.formula || "0"));
            } catch (e) {
                damage = 0;
            }

            if (this._type === "arrow") {
                var actor2 = this._user && this._user.playerBattler ? this._user.playerBattler() : null;
                if (actor2 && actor2.cachedAmmoAtk) {
                    damage += actor2.cachedAmmoAtk();
                    if (actor2.clearCachedAmmoAtk) actor2.clearCachedAmmoAtk();
                }
            }

            if (skill.damage.type === 1) {
                critical = Math.random() < ((actor.cri || 0) + 0.1);
                if (critical) damage = Math.floor(damage * 1.5);
            }

            var variance = skill.damage.variance || 0;
            if (variance > 0) {
                var amp = Math.floor(Math.abs(damage) * variance / 100);
                damage += Math.floor(Math.random() * (amp * 2 + 1)) - amp;
            }

            if (skill.damage.type === 1) {
                damage = Math.max(0, damage);
            } else if (skill.damage.type === 3) {
                damage = -Math.max(0, damage);
            } else {
                damage = 0;
            }
        }

        if (skill.animationId && skill.animationId > 0) {
            $gameTemp.requestAnimation([enemyEvent], skill.animationId);
        }

        if (damage > 0) {
            enemyEvent._hp = Math.max(0, enemyEvent._hp - damage);
            if (enemyEvent._enemyEntity.setHp) {
                enemyEvent._enemyEntity.setHp(enemyEvent._hp);
            }
            if (enemyEvent.showDamageText) {
                enemyEvent.showDamageText(
                    String(damage),
                    critical ? "#ffff66" : "#ff6666",
                    critical ? 28 : 22
                );
            }

            if (critical) {
                this.knockbackTarget(enemyEvent, this._direction);
            }
        } else if (damage < 0) {
            enemyEvent._hp = Math.min(enemyEvent._enemyEntity.mhp, enemyEvent._hp - damage);
            if (enemyEvent._enemyEntity.setHp) {
                enemyEvent._enemyEntity.setHp(enemyEvent._hp);
            }
            if (enemyEvent.showDamageText) {
                enemyEvent.showDamageText(String(-damage), "#66ff99");
            }
        } else {
            if (enemyEvent.showDamageText) {
                enemyEvent.showDamageText("0", "#ffffff");
            }
        }
    };

