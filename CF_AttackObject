//=============================================================================
// CF DotMove Integration
// 直接内置 DotMoveSystem 兼容：真实坐标攻击体、真实坐标碰撞。
//=============================================================================
"use strict";

    var EPS = 0.00001;
    var DIAG = Math.SQRT1_2 || (1 / Math.sqrt(2));

    function hasDotMove() {
        return !!(
            window.Game_CharacterBase &&
            Game_CharacterBase.prototype &&
            Game_CharacterBase.prototype.centerRealX &&
            Game_CharacterBase.prototype.centerRealY
        );
    }

    function numberOr(value, fallback) {
        var n = Number(value);
        return isFinite(n) ? n : fallback;
    }

    function noteNumber(note, tagName, fallback) {
        note = note || "";
        var re = new RegExp("<" + tagName + ":\\s*([0-9.]+)\\s*>", "i");
        var m = note.match(re);
        return m ? numberOr(m[1], fallback) : fallback;
    }

    function dirVector(d) {
        switch (d) {
            case 1: return { x: -DIAG, y:  DIAG };
            case 2: return { x: 0,     y:  1    };
            case 3: return { x:  DIAG, y:  DIAG };
            case 4: return { x: -1,    y:  0    };
            case 6: return { x:  1,    y:  0    };
            case 7: return { x: -DIAG, y: -DIAG };
            case 8: return { x: 0,     y: -1    };
            case 9: return { x:  DIAG, y: -DIAG };
            default: return { x: 0, y: 0 };
        }
    }

    function dirToHV(d) {
        switch (d) {
            case 1: return [4, 2];
            case 3: return [6, 2];
            case 7: return [4, 8];
            case 9: return [6, 8];
            default: return [0, 0];
        }
    }

    function charX(ch) {
        if (!ch) return 0;
        if (ch._realX != null) return Number(ch._realX || 0);
        if (ch._x != null) return Number(ch._x || 0);
        return Number(ch.x || 0);
    }

    function charY(ch) {
        if (!ch) return 0;
        if (ch._realY != null) return Number(ch._realY || 0);
        if (ch._y != null) return Number(ch._y || 0);
        return Number(ch.y || 0);
    }

    function charWidth(ch) {
        if (!ch) return 1;
        if (typeof ch.width === "function") return Math.max(0.1, Number(ch.width() || 1));
        return 1;
    }

    function charHeight(ch) {
        if (!ch) return 1;
        if (typeof ch.height === "function") return Math.max(0.1, Number(ch.height() || 1));
        return 1;
    }

    function charCenterX(ch) {
        if (!ch) return 0;
        if (typeof ch.centerRealX === "function") return Number(ch.centerRealX() || 0);
        return charX(ch) + charWidth(ch) / 2;
    }

    function charCenterY(ch) {
        if (!ch) return 0;
        if (typeof ch.centerRealY === "function") return Number(ch.centerRealY() || 0);
        return charY(ch) + charHeight(ch) / 2;
    }

    function charRadius(ch) {
        return Math.max(charWidth(ch), charHeight(ch)) * 0.5;
    }

    function facingDir(ch) {
        if (!ch) return 2;
        if (typeof ch.cfInteractionDirection === "function") return ch.cfInteractionDirection();
        return ch.direction ? ch.direction() : 2;
    }

    function mapPassableAtCenter(cx, cy, d) {
        var tx = Math.floor(cx);
        var ty = Math.floor(cy);

        if (!$gameMap || !$gameMap.isValid(tx, ty)) return false;

        if (d === 1 || d === 3 || d === 7 || d === 9) {
            var hv = dirToHV(d);
            return $gameMap.isPassable(tx, ty, hv[0]) && $gameMap.isPassable(tx, ty, hv[1]);
        }

        return $gameMap.isPassable(tx, ty, d || 2);
    }

    function requestAnimation(targets, animationId) {
        if (animationId && animationId > 0 && $gameTemp && $gameTemp.requestAnimation) {
            $gameTemp.requestAnimation(targets, animationId);
        }
    }

    function playMiss() {
        if (window.SoundManager && SoundManager.playMiss) SoundManager.playMiss();
    }

    function DotMoveAttackObject() {
        this.initialize.apply(this, arguments);
    }

    DotMoveAttackObject.prototype.initialize = function(user, skill, type, startX, startY, startDir) {
        this._user = user;
        this._skill = skill;
        this._skillId = skill ? skill.id : 0;
        this._type = type || "slash";

        this._fromEnemy = (user instanceof Game_Event);
        this._fromPlayer = (user instanceof Game_Player);

        this._direction = (startDir != null ? startDir : facingDir(user));
        if (!this._direction || this._direction <= 0) this._direction = 2;

        this._finished = false;
        this._hitEnemies = [];
        this._hitEnemyMap = Object.create(null);
        this._hitPlayer = false;
        this._frameCount = 0;
        this._pattern = 0;
        this._moveWait = 0;

        this._range = this.readSkillRange(skill);
        this._remainingDistance = this._range;

        this._damageEnabled = true;
        this._reachMaxRange = false;
        this._hasHit = false;

        this._startedFromCustomPos = (startX != null || startY != null);
        this._x = (startX != null ? Number(startX) : charX(user));
        this._y = (startY != null ? Number(startY) : charY(user));

        this.setupByType();

        if (!this._startedFromCustomPos) {
            this.forwardStart();
        }
    };

    DotMoveAttackObject.prototype.readSkillRange = function(skill) {
        if (!skill) return 1;
        var note = skill.note || "";
        var match = note.match(/<range:\s*(\d+(?:\.\d+)?)\s*>/i);
        return match ? Math.max(0.25, Number(match[1])) : 1;
    };

    DotMoveAttackObject.prototype.readSkillAttackObjectPic = function(skill) {
        if (!skill) return "";
        var note = skill.note || "";
        var match = note.match(/<attackObjectPic:([^>]+)>/i);
        return match ? String(match[1]).trim() : "";
    };

    DotMoveAttackObject.prototype.minVisualFramesByType = function() {
        if (this._type === "slash") return 6;
        if (this._type === "punch") return 4;
        if (this._type === "arrow") return 0;
        return 4;
    };

    DotMoveAttackObject.prototype.isMeleeType = function() {
        return this._type === "slash" || this._type === "punch";
    };

    DotMoveAttackObject.prototype.setupByType = function() {
        var customPic = this.readSkillAttackObjectPic(this._skill);
        var note = this._skill ? (this._skill.note || "") : "";

        this._minVisualFrames = this.minVisualFramesByType();

        if (this._type === "arrow") {
            this._speedFrame = Math.max(1, Math.floor(noteNumber(note, "aoSpeedFrame", 2)));
            this._moveStep = noteNumber(note, "aoMoveStep", 0.25);
            this._hitRadius = noteNumber(note, "aoHitRadius", 0.32);
            this._startOffset = noteNumber(note, "aoStartOffset", 0.50);
            this._pictureName = customPic || "Arrow";
        } else if (this._type === "punch") {
            this._speedFrame = Math.max(1, Math.floor(noteNumber(note, "aoSpeedFrame", 2)));
            this._moveStep = noteNumber(note, "aoMoveStep", 0.20);
            this._hitRadius = noteNumber(note, "aoHitRadius", 0.62);
            // Melee keeps the old CF half-step feel by default.
            this._startOffset = noteNumber(note, "aoStartOffset", 0.50);
            this._pictureName = customPic || "";
        } else {
            this._speedFrame = Math.max(1, Math.floor(noteNumber(note, "aoSpeedFrame", 2)));
            this._moveStep = noteNumber(note, "aoMoveStep", 0.20);
            this._hitRadius = noteNumber(note, "aoHitRadius", 0.72);
            // Melee keeps the old CF half-step feel by default.
            this._startOffset = noteNumber(note, "aoStartOffset", 0.50);
            this._pictureName = customPic || "Sword";
        }

        this._throughAfterHit = /<powerArrow>/i.test(note);

        // Melee attacks are area attacks by default.
        // This allows a widened slash/punch corridor to damage every enemy inside it,
        // instead of stopping at the first enemy found.
        // Use <aoSingleHit> on a skill if you want old single-target melee behavior.
        this._multiHit = !/<aoSingleHit>/i.test(note) && (
            /<aoMultiHit>/i.test(note) || this._type === "slash" || this._type === "punch"
        );

        this._moveStep = Math.max(0.05, Number(this._moveStep || 0.2));
        this._hitRadius = Math.max(0.05, Number(this._hitRadius || 0.5));

        if (this.isMeleeType()) {
            // Width only: one tile wide plus both sides extended.
            // Does not increase forward distance.
            this._meleeSideExtend = Math.max(0, noteNumber(note, "aoMeleeSideExtend", 0.20));

            // Original CF melee used half-step attack points.
            // <range:1> checks the first half-step in front, not a full tile ahead.
            this._meleeRangeUnit = Math.max(0.05, noteNumber(note, "aoMeleeRangeUnit", 0.50));
