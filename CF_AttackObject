            }

            var variance = skill.damage.variance || 0;
            if (variance > 0) {
                var amp = Math.floor(Math.abs(damage) * variance / 100);
                damage += Math.floor(Math.random() * (amp * 2 + 1)) - amp;
            }

            if (skill.damage.type === 1) damage = Math.max(0, damage);
            else if (skill.damage.type === 3) damage = -Math.max(0, damage);
