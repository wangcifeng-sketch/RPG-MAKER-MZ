        // The side band can be widened, but the forward distance is not enlarged.
        var tw = charWidth(target);
        var th = charHeight(target);
        var targetForwardHalf = Math.abs(v.x) * tw * 0.5 + Math.abs(v.y) * th * 0.5;
        var targetLateralHalf = Math.abs(v.y) * tw * 0.5 + Math.abs(v.x) * th * 0.5;

